---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { breadcrumbSchema, collectionPageSchema, itemListSchema } from '../data/seo.mjs';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const officialLinks = [
  {
    title: 'OpenClaw 官网',
    tag: '官方入口',
    url: 'https://openclaw.ai/',
    summary: '获取官方入口、安装包、产品更新和公开动态。'
  },
  {
    title: 'OpenClaw 官方文档',
    tag: '官方文档',
    url: 'https://docs.openclaw.ai/',
    summary: '完整技术手册，适合查安装、配置、接入和高级参数。'
  },
  {
    title: 'GitHub 仓库',
    tag: '源码与讨论',
    url: 'https://github.com/openclaw/openclaw',
    summary: '源码所在地，也是提 Issue、看讨论和跟进开发进展的主入口。'
  },
  {
    title: 'OpenClaw 中文文档',
    tag: '中文社区',
    url: 'https://openclaw.cc/',
    summary: '社区维护的中文指南，更适合国内用户快速查阅。'
  }
];

const skillLinks = [
  {
    title: '腾讯 SkillHub',
    tag: '技能入口',
    url: 'https://skillhub.tencent.com/',
    summary: '国内常用的技能入口之一，适合继续找可用技能和生态资源。'
  },
  {
    title: 'ClawHub',
    tag: '官方技能市场',
    url: 'https://clawhub.ai/',
    summary: '官方技能注册表，适合集中浏览 OpenClaw 技能生态。'
  },
  {
    title: 'Awesome OpenClaw Skills',
    tag: '社区精选',
    url: 'https://github.com/VoltAgent/awesome-openclaw-skills',
    summary: '社区精选审计后的技能清单，适合优先从这里挑安全技能。'
  },
  {
    title: 'Skills.sh',
    tag: '跨平台技能市场',
    url: 'https://skills.sh/',
    summary: '更大的跨平台技能市场，SKILL.md 与 OpenClaw 通用。'
  },
  {
    title: 'AgentSkills 规范',
    tag: '技能标准',
    url: 'https://agentskills.io/',
    summary: '自建技能、发布技能或做技能变现时可参考的规范入口。'
  }
];

const usecaseLinks = [
  {
    title: 'Awesome OpenClaw Usecases',
    tag: '案例集合',
    url: 'https://github.com/hesamsheikh/awesome-openclaw-usecases',
    summary: '社区真实 Agent 应用案例合集，适合看别人怎么落地。'
  },
  {
    title: '案例页',
    tag: '站内入口',
    url: withBase('/cases/'),
    summary: '站内整理的个人场景、专业场景和行业解决方案入口。'
  },
  {
    title: '文档教程',
    tag: '站内入口',
    url: withBase('/docs/'),
    summary: '安装步骤、命令、FAQ 和参考配置都可以从这里继续。'
  },
  {
    title: '定制交付',
    tag: '站内入口',
    url: withBase('/service/'),
    summary: '部署、定制解决方案、教学陪跑和联系入口都在这里。'
  }
];

const modelLinks = [
  {
    title: 'OpenRouter',
    tag: '国际模型聚合',
    url: 'https://openrouter.ai/',
    summary: '适合统一接入多模型，并利用 fallback 机制做备选链。'
  },
  {
    title: 'MiniMax 平台',
    tag: '模型平台',
    url: 'https://platform.minimaxi.com/subscribe/coding-plan',
    summary: '如果准备在 OpenClaw 里接入 MiniMax，这里是平台入口。'
  },
  {
    title: 'DeepSeek 开放平台',
    tag: '国产模型',
    url: 'https://platform.deepseek.com/',
    summary: '高性价比国产模型平台，适合国内常见接入方案。'
  },
  {
    title: '硅基流动 SiliconFlow',
    tag: '模型聚合',
    url: 'https://siliconflow.cn/',
    summary: '国内模型聚合平台，适合统一调用多种开源模型。'
  },
  {
    title: '阿里云百炼',
    tag: '模型聚合',
    url: 'https://bailian.console.aliyun.com/cn-beijing?tab=coding-plan#/efm/index',
    summary: '阿里云的模型与应用平台，也适合作为国内模型聚合接入入口。'
  },
  {
    title: 'Kimi 大模型平台',
    tag: '模型平台',
    url: 'https://www.kimi.com/code?from=kfc_overview_topbar',
    summary: 'Moonshot 的模型与编程平台入口，也适合作为国内模型接入选择。'
  },
  {
    title: 'Ollama',
    tag: '本地模型',
    url: 'https://ollama.ai/',
    summary: '个人用户在本地运行开源模型时最常用的方案之一。'
  },
  {
    title: 'LM Studio',
    tag: '本地测试',
    url: 'https://lmstudio.ai/',
    summary: '带图形界面的本地模型管理工具，适合测试模型的工具调用支持。'
  }
];

const groups = [
  {
    id: 'official',
    label: '官方',
    title: '官方入口',
    note: '安装、升级、看发布和查权威说明，优先走官方入口。',
    links: officialLinks
  },
  {
    id: 'skills',
    label: '技能',
    title: '技能与安全',
    note: '找技能、筛技能、做技能和检查技能安全，集中看这一组。',
    links: skillLinks
  },
  {
    id: 'usecases',
    label: '案例',
    title: '案例与学习入口',
    note: '先看别人怎么落地，再回到站内继续学和继续配。',
    links: usecaseLinks
  },
  {
    id: 'models',
    label: '模型',
    title: '模型与本地运行',
    note: '准备接模型平台或本地跑模型时，从这组入口继续。',
    links: modelLinks
  }
];

const linkKeywords = [
  'OpenClaw 官网',
  'OpenClaw 官方文档',
  'OpenClaw GitHub',
  'OpenClaw 技能市场',
  'OpenClaw 模型平台',
  'OpenClaw 资源导航'
];

const linkStructuredData = [
  collectionPageSchema({
    site: Astro.site,
    path: '/links/',
    name: 'OpenClaw 资源导航',
    description: '集中整理 OpenClaw 官网、官方文档、GitHub、技能市场、案例入口和模型平台。',
    keywords: linkKeywords,
    about: ['OpenClaw 官网', 'OpenClaw 官方文档', 'OpenClaw 技能市场', '模型平台']
  }),
  itemListSchema({
    site: Astro.site,
    path: '/links/',
    name: 'OpenClaw 常用入口分类',
    items: groups.map((group) => ({
      name: group.title,
      path: `/links/#${group.id}`
    }))
  }),
  breadcrumbSchema(Astro.site, [
    { name: '首页', path: '/' },
    { name: '资源导航', path: '/links/' }
  ])
];
---

<MarketingLayout
  title="OpenClaw 资源导航 | 官网、文档、技能市场与模型平台 | 虾客AI"
  description="集中整理 OpenClaw 官网、官方文档、GitHub、技能市场、案例入口和模型平台，查资料时可以直接进入对应入口。"
  keywords={linkKeywords}
  structuredData={linkStructuredData}
>
  <main class="page" id="main-content">
    <div class="container nav-page">
      <section class="nav-hub">
        <div class="nav-hub__heading">
          <span class="eyebrow">资源导航</span>
          <h1>OpenClaw 常用入口</h1>
          <p class="lead">把官网、文档、技能生态、案例入口和模型平台按类别整理，查资料时可以直接进入对应入口。</p>
        </div>

        <div class="nav-hub__tools">
          <div class="nav-hub__jump">
            {groups.map((group) => (
              <a href={`#${group.id}`}>{group.label}</a>
            ))}
          </div>
          <div class="nav-hub__quick">
            <a class="button button-primary" href="https://openclaw.ai/" target="_blank" rel="noreferrer">打开官网</a>
            <a class="button button-secondary" href="https://docs.openclaw.ai/" target="_blank" rel="noreferrer">
              官方文档
            </a>
          </div>
        </div>
      </section>

      {
        groups.map((group) => (
          <section class="nav-group section" id={group.id}>
            <div class="nav-group__bar">
              <div>
                <span class="section-kicker">{group.title}</span>
                <p class="nav-group__note">{group.note}</p>
              </div>
            </div>

            <div class="nav-grid">
              {group.links.map((item) => (
                <a class="nav-card" href={item.url} target={item.url.startsWith('http') ? '_blank' : undefined} rel={item.url.startsWith('http') ? 'noreferrer' : undefined}>
                  <span class="card-tag">{item.tag}</span>
                  <h3 class="nav-card__title">{item.title}</h3>
                  <p class="nav-card__summary">{item.summary}</p>
                  <span class="nav-card__action">{item.url.startsWith('http') ? '打开链接' : '进入页面'}</span>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </main>

  <style>
    .nav-page {
      display: grid;
      gap: 18px;
    }

    .nav-hub {
      display: grid;
      gap: 14px;
      padding: 14px 16px;
      border: 1px solid rgba(91, 68, 52, 0.1);
      border-radius: var(--radius-xl);
      background:
        linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(250, 245, 239, 0.94)),
        radial-gradient(circle at top right, rgba(186, 99, 54, 0.06), transparent 28%);
      box-shadow: 0 12px 28px rgba(73, 52, 38, 0.06);
    }

    .nav-hub__heading {
      display: grid;
      gap: 10px;
    }

    .nav-hub__heading h1,
    .nav-hub__heading p {
      margin: 0;
    }

    .nav-hub__tools {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .nav-hub__jump {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .nav-hub__jump a {
      display: inline-flex;
      align-items: center;
      min-height: 40px;
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(91, 68, 52, 0.1);
      background: rgba(255, 252, 248, 0.88);
      color: var(--accent-deep);
      font-size: 0.88rem;
    }

    .nav-hub__quick {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .nav-group {
      padding-top: 0;
    }

    .nav-group__bar {
      display: flex;
      align-items: end;
      gap: 12px;
      margin-bottom: 12px;
      padding: 0 4px;
    }

    .nav-group__bar > div {
      display: grid;
      gap: 4px;
    }

    .nav-group__note {
      margin: 0;
      max-width: 40rem;
      color: var(--muted);
      font-size: 0.96rem;
      line-height: 1.6;
    }

    .nav-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    .nav-card {
      display: grid;
      align-content: start;
      gap: 8px;
      min-height: 188px;
      padding: 14px;
      border-radius: 20px;
      border: 1px solid rgba(91, 68, 52, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(250, 245, 239, 0.94));
      box-shadow: 0 10px 24px rgba(73, 52, 38, 0.05);
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        box-shadow 180ms ease;
    }

    .nav-card:hover,
    .nav-card:focus-visible {
      transform: translateY(-2px);
      border-color: rgba(186, 99, 54, 0.2);
      box-shadow: 0 14px 28px rgba(73, 52, 38, 0.08);
    }

    .nav-card__title,
    .nav-card__summary,
    .nav-card__action {
      margin: 0;
    }

    .nav-card__title {
      font-size: 1.08rem;
      line-height: 1.2;
    }

    .nav-card__summary {
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.62;
    }

    .nav-card__action {
      margin-top: auto;
      color: var(--accent-deep);
      font-size: 0.84rem;
      font-weight: 700;
    }

    @media (max-width: 1100px) {
      .nav-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 840px) {
      .nav-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .nav-group__bar {
        flex-direction: column;
        align-items: start;
      }
    }

    @media (max-width: 640px) {
      .nav-hub {
        padding: 14px;
      }

      .nav-grid {
        grid-template-columns: 1fr;
      }

      .nav-card {
        min-height: 0;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .nav-card {
        transition: none;
      }
    }
  </style>
</MarketingLayout>
