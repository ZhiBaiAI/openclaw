---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const officialLinks = [
  {
    title: 'OpenClaw 官网',
    tag: '官方入口',
    url: 'https://openclaw.ai/',
    summary: '先看产品定位、安装方式、支持平台和官方下载安装入口。'
  },
  {
    title: 'OpenClaw 官方文档',
    tag: '官方文档',
    url: 'https://docs.openclaw.ai/',
    summary: '查安装、配置、聊天渠道接入和更细的官方说明。'
  },
  {
    title: 'GitHub 仓库',
    tag: '源码与讨论',
    url: 'https://github.com/openclaw/openclaw',
    summary: '查看源码、Issue、讨论和最近动态。'
  },
  {
    title: 'GitHub Releases',
    tag: '版本更新',
    url: 'https://github.com/openclaw/openclaw/releases',
    summary: '升级前先看版本说明、发布时间和变更记录。'
  }
];

const toolLinks = [
  {
    title: '腾讯 SkillHub',
    tag: '技能入口',
    url: 'https://skillhub.tencent.com/',
    summary: '需要扩展能力时，从这里找可用技能。'
  },
  {
    title: 'MiniMax 平台',
    tag: '模型平台',
    url: 'https://platform.minimaxi.com/subscribe/coding-plan',
    summary: '如果你准备在 OpenClaw 里接 MiniMax，这里是平台入口。'
  },
  {
    title: 'ClawHub',
    tag: '生态入口',
    url: 'https://clawhub.ai/',
    summary: '补充看 OpenClaw 生态内容、案例和周边资源。'
  }
];

const readingLinks = [
  {
    title: 'OpenClaw + QQ 入门文章',
    url: 'https://cloud.tencent.com/developer/article/2625147',
    summary: '更偏新手向，适合先跑通第一个聊天入口。'
  },
  {
    title: 'OpenClaw 接入微信',
    url: 'https://cloud.tencent.com/developer/article/2626045',
    summary: '适合想把 OpenClaw 用进高频沟通入口的人。'
  },
  {
    title: 'OpenClaw 接入飞书',
    url: 'https://cloud.tencent.com/developer/article/2626151',
    summary: '适合办公协同和团队沟通场景。'
  },
  {
    title: 'OpenClaw 接入钉钉',
    url: 'https://cloud.tencent.com/developer/article/2626553',
    summary: '适合值守、通知和企业协同类场景。'
  }
];

const localRoutes = [
  {
    title: '文档教程',
    url: withBase('/docs/'),
    summary: '把 7 步教程、命令和 FAQ 集中放在本站。'
  },
  {
    title: '案例',
    url: withBase('/cases/'),
    summary: '先看有哪些适合新手理解的真实使用场景。'
  },
  {
    title: '安装交付服务',
    url: withBase('/service/'),
    summary: '自己安装、交付服务、排错支持都统一在这里。'
  }
];
---

<MarketingLayout
  title="OpenClaw 资源导航"
  description="集中整理官网、官方文档、SkillHub、版本更新和精选中文文章，作为 OpenClaw 的外部资源入口。"
>
  <main class="page">
    <div class="container">
      <section class="page-hero">
        <div class="hero-grid">
          <article>
            <span class="eyebrow">资源导航</span>
            <h1>官网、官方文档、SkillHub 和精选文章，都放在这一页。</h1>
            <p class="lead">
              你不需要每次都重新翻聊天记录找链接。需要查官方资料、看技能入口、补外部文章时，
              直接来这一页就够了。
            </p>
            <div class="action-row">
              <a class="button button-primary" href="https://openclaw.ai/" target="_blank" rel="noreferrer">
                打开官网
              </a>
              <a class="button button-secondary" href="https://docs.openclaw.ai/" target="_blank" rel="noreferrer">
                打开官方文档
              </a>
            </div>
          </article>

          <aside class="hero-aside">
            <span class="section-kicker">建议顺序</span>
            <ul class="simple-list">
              <li>第一次使用：先看官网，再看官方文档。</li>
              <li>想扩展能力：再去 SkillHub 找技能。</li>
              <li>准备升级或排错：看 Releases 和 GitHub 仓库。</li>
            </ul>
          </aside>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <div>
            <span class="section-kicker">官方入口</span>
            <h2>安装、配置、升级，优先以官方信息为准。</h2>
          </div>
          <p class="section-copy">
            第三方文章适合辅助理解，但安装步骤、权限、更新与兼容性，还是优先参考官方入口。
          </p>
        </div>

        <div class="card-grid card-grid-two">
          {officialLinks.map((item) => (
            <article class="info-card">
              <span class="card-tag">{item.tag}</span>
              <h3 class="card-title">{item.title}</h3>
              <p class="card-meta">{item.summary}</p>
              <div class="action-row">
                <a class="button button-secondary" href={item.url} target="_blank" rel="noreferrer">
                  打开链接
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="split-grid">
          <article class="summary-card">
            <span class="section-kicker">工具与生态</span>
            <h2>需要扩展能力、补模型平台或看生态内容时，再来这里。</h2>
            <div class="mini-grid">
              {toolLinks.map((item) => (
                <a class="mini-card" href={item.url} target="_blank" rel="noreferrer">
                  <strong>{item.title}</strong>
                  <span>{item.summary}</span>
                </a>
              ))}
            </div>
          </article>

          <article class="note-card">
            <span class="status-chip support">提醒</span>
            <h3 class="card-title">SkillHub 放在资源页，不放在顶部主菜单。</h3>
            <p class="card-meta">
              这样首页结构更干净。只有在你明确需要外部资源和技能入口时，才进入资源导航。
            </p>
          </article>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <div>
            <span class="section-kicker">精选文章</span>
            <h2>适合补充看具体聊天入口和场景接入。</h2>
          </div>
          <p class="section-copy">
            这些文章更偏场景理解，适合新手补概念，不建议代替官方步骤。
          </p>
        </div>

        <div class="card-grid card-grid-two">
          {readingLinks.map((item) => (
            <article class="info-card">
              <span class="card-tag">外部文章</span>
              <h3 class="card-title">{item.title}</h3>
              <p class="card-meta">{item.summary}</p>
              <div class="action-row">
                <a class="button button-secondary" href={item.url} target="_blank" rel="noreferrer">
                  查看文章
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="split-grid">
          <article class="summary-card">
            <span class="section-kicker">站内入口</span>
            <h2>看完外部链接后，通常会回到这三个站内页面。</h2>
            <div class="mini-grid">
              {localRoutes.map((item) => (
                <a class="mini-card" href={item.url}>
                  <strong>{item.title}</strong>
                  <span>{item.summary}</span>
                </a>
              ))}
            </div>
          </article>

          <article class="note-card">
            <span class="status-chip">收藏建议</span>
            <h3 class="card-title">如果你每天都在用 OpenClaw，这页最好也一起收藏。</h3>
            <p class="card-meta">
              它负责所有“站外资源”的统一入口，能把官网、技能、版本和补充文章收在一处。
            </p>
          </article>
        </div>
      </section>
    </div>
  </main>

  <style>
    .card-grid-two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    @media (max-width: 960px) {
      .card-grid-two {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MarketingLayout>
