---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const officialLinks = [
  {
    title: 'OpenClaw 官网',
    tag: '官方入口',
    url: 'https://openclaw.ai/',
    summary: '看产品定位、安装方式、支持平台和官方安装入口。'
  },
  {
    title: 'OpenClaw 官方文档',
    tag: '官方文档',
    url: 'https://docs.openclaw.ai/',
    summary: '查安装、配置、聊天渠道接入和更详细的官方说明。'
  },
  {
    title: 'GitHub 仓库',
    tag: '源码与讨论',
    url: 'https://github.com/openclaw/openclaw',
    summary: '查看源码、Issue、讨论和最近动态。'
  },
  {
    title: 'GitHub Releases',
    tag: '版本更新',
    url: 'https://github.com/openclaw/openclaw/releases',
    summary: '升级前先看版本说明、发布时间和变更记录。'
  }
];

const toolLinks = [
  {
    title: '腾讯 SkillHub',
    tag: '技能入口',
    url: 'https://skillhub.tencent.com/',
    summary: '需要扩展能力时，从这里找可用技能。'
  },
  {
    title: 'MiniMax 平台',
    tag: '模型平台',
    url: 'https://platform.minimaxi.com/subscribe/coding-plan',
    summary: '如果准备在 OpenClaw 里接入 MiniMax，这里是平台入口。'
  },
  {
    title: 'ClawHub',
    tag: '生态入口',
    url: 'https://clawhub.ai/',
    summary: '补充看 OpenClaw 生态内容、案例和周边资源。'
  }
];

const readingLinks = [
  {
    title: 'OpenClaw + QQ 入门文章',
    tag: '外部文章',
    url: 'https://cloud.tencent.com/developer/article/2625147',
    summary: '更偏新手向，适合先跑通第一个聊天入口。'
  },
  {
    title: 'OpenClaw 接入微信',
    tag: '外部文章',
    url: 'https://cloud.tencent.com/developer/article/2626045',
    summary: '适合想把 OpenClaw 用进高频沟通入口的人。'
  },
  {
    title: 'OpenClaw 接入飞书',
    tag: '外部文章',
    url: 'https://cloud.tencent.com/developer/article/2626151',
    summary: '适合办公协同和团队沟通场景。'
  },
  {
    title: 'OpenClaw 接入钉钉',
    tag: '外部文章',
    url: 'https://cloud.tencent.com/developer/article/2626553',
    summary: '适合通知、值守和企业协同类场景。'
  }
];

const localRoutes = [
  {
    title: '文档教程',
    tag: '站内入口',
    url: withBase('/docs/'),
    summary: '7 步总览、命令和 FAQ 都集中在站内。'
  },
  {
    title: '案例',
    tag: '站内入口',
    url: withBase('/cases/'),
    summary: '先看哪些场景值得做，再决定投入多少时间。'
  },
  {
    title: '安装交付服务',
    tag: '站内入口',
    url: withBase('/service/'),
    summary: '自己安装、交付服务、排错支持都统一在这里。'
  }
];

const groups = [
  {
    id: 'official',
    label: '官方',
    title: '官方入口',
    note: '安装、配置、升级，优先以官方信息为准。',
    links: officialLinks
  },
  {
    id: 'tools',
    label: '生态',
    title: '工具与生态',
    note: '需要扩展能力、补模型平台或看生态内容时，再来这里。',
    links: toolLinks
  },
  {
    id: 'reading',
    label: '文章',
    title: '精选文章',
    note: '更偏场景理解，适合补概念，不建议替代官方步骤。',
    links: readingLinks
  },
  {
    id: 'inside',
    label: '站内',
    title: '站内入口',
    note: '看完外部链接后，通常会回到这几个站内页面继续操作。',
    links: localRoutes
  }
];
---

<MarketingLayout
  title="虾客AI 资源导航"
  description="集中整理官网、官方文档、SkillHub、版本更新和精选中文文章，作为 OpenClaw 的外部资源入口。"
>
  <main class="page" id="main-content">
    <div class="container nav-page">
      <section class="nav-hub">
        <div class="nav-hub__heading">
          <span class="eyebrow">资源导航</span>
          <h1>OpenClaw 常用入口</h1>
          <p class="lead">把官网、文档、生态工具和相关文章按类别整理，查资料时可以直接进入对应入口。</p>
        </div>

        <div class="nav-hub__tools">
          <div class="nav-hub__jump">
            {groups.map((group) => (
              <a href={`#${group.id}`}>{group.label}</a>
            ))}
          </div>
          <div class="nav-hub__quick">
            <a class="button button-primary" href="https://openclaw.ai/" target="_blank" rel="noreferrer">打开官网</a>
            <a class="button button-secondary" href="https://docs.openclaw.ai/" target="_blank" rel="noreferrer">
              官方文档
            </a>
          </div>
        </div>
      </section>

      {
        groups.map((group) => (
          <section class="nav-group section" id={group.id}>
            <div class="nav-group__bar">
              <div>
                <span class="section-kicker">{group.title}</span>
                <p class="nav-group__note">{group.note}</p>
              </div>
            </div>

            <div class="nav-grid">
              {group.links.map((item) => (
                <a class="nav-card" href={item.url} target={item.url.startsWith('http') ? '_blank' : undefined} rel={item.url.startsWith('http') ? 'noreferrer' : undefined}>
                  <span class="card-tag">{item.tag}</span>
                  <h3 class="nav-card__title">{item.title}</h3>
                  <p class="nav-card__summary">{item.summary}</p>
                  <span class="nav-card__action">{item.url.startsWith('http') ? '打开链接' : '进入页面'}</span>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </main>

  <style>
    .nav-page {
      display: grid;
      gap: 18px;
    }

    .nav-hub {
      display: grid;
      gap: 14px;
      padding: 14px 16px;
      border: 1px solid rgba(91, 68, 52, 0.1);
      border-radius: var(--radius-xl);
      background:
        linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(250, 245, 239, 0.94)),
        radial-gradient(circle at top right, rgba(186, 99, 54, 0.06), transparent 28%);
      box-shadow: 0 12px 28px rgba(73, 52, 38, 0.06);
    }

    .nav-hub__heading {
      display: grid;
      gap: 10px;
    }

    .nav-hub__heading h1,
    .nav-hub__heading p {
      margin: 0;
    }

    .nav-hub__tools {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .nav-hub__jump {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .nav-hub__jump a {
      display: inline-flex;
      align-items: center;
      min-height: 40px;
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(91, 68, 52, 0.1);
      background: rgba(255, 252, 248, 0.88);
      color: var(--accent-deep);
      font-size: 0.88rem;
    }

    .nav-hub__quick {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .nav-group {
      padding-top: 0;
    }

    .nav-group__bar {
      display: flex;
      align-items: end;
      gap: 12px;
      margin-bottom: 12px;
      padding: 0 4px;
    }

    .nav-group__bar > div {
      display: grid;
      gap: 4px;
    }

    .nav-group__note {
      margin: 0;
      max-width: 40rem;
      color: var(--muted);
      font-size: 0.96rem;
      line-height: 1.6;
    }

    .nav-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    .nav-card {
      display: grid;
      align-content: start;
      gap: 8px;
      min-height: 188px;
      padding: 14px;
      border-radius: 20px;
      border: 1px solid rgba(91, 68, 52, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(250, 245, 239, 0.94));
      box-shadow: 0 10px 24px rgba(73, 52, 38, 0.05);
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        box-shadow 180ms ease;
    }

    .nav-card:hover,
    .nav-card:focus-visible {
      transform: translateY(-2px);
      border-color: rgba(186, 99, 54, 0.2);
      box-shadow: 0 14px 28px rgba(73, 52, 38, 0.08);
    }

    .nav-card__title,
    .nav-card__summary,
    .nav-card__action {
      margin: 0;
    }

    .nav-card__title {
      font-size: 1.08rem;
      line-height: 1.2;
    }

    .nav-card__summary {
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.62;
    }

    .nav-card__action {
      margin-top: auto;
      color: var(--accent-deep);
      font-size: 0.84rem;
      font-weight: 700;
    }

    @media (max-width: 1100px) {
      .nav-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 840px) {
      .nav-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .nav-group__bar {
        flex-direction: column;
        align-items: start;
      }
    }

    @media (max-width: 640px) {
      .nav-hub {
        padding: 14px;
      }

      .nav-grid {
        grid-template-columns: 1fr;
      }

      .nav-card {
        min-height: 0;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .nav-card {
        transition: none;
      }
    }
  </style>
</MarketingLayout>
