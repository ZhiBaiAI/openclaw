---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const officialLinks = [
  {
    title: 'OpenClaw 官网',
    tag: '官方首页',
    url: 'https://openclaw.ai/',
    summary: '先看产品定位、安装方式、平台支持和官方下载安装入口。',
    note: '适合第一次了解 OpenClaw 的用户'
  },
  {
    title: 'OpenClaw 官方文档',
    tag: '官方文档',
    url: 'https://docs.openclaw.ai/',
    summary: '查安装、配置、聊天渠道接入、远程访问和常见问题。',
    note: '需要精确步骤时优先看这里'
  },
  {
    title: '腾讯 SkillHub',
    tag: '技能入口',
    url: 'https://skillhub.tencent.com/',
    summary: '统一跳转到腾讯 SkillHub 查找和获取可用技能，不在本站单独做技能市场。',
    note: '需要扩展能力时，直接从这里进入'
  },
  {
    title: 'GitHub 仓库',
    tag: '源码与讨论',
    url: 'https://github.com/openclaw/openclaw',
    summary: '查看源码、Issue、更新动态和社区讨论。',
    note: '适合跟踪官方进展和问题反馈'
  },
  {
    title: 'GitHub Releases',
    tag: '版本发布',
    url: 'https://github.com/openclaw/openclaw/releases',
    summary: '集中查看版本更新记录、发布时间和升级说明。',
    note: '升级前建议先看这里'
  }
];

const articleLinks = [
  {
    title: '小白也能轻松入手！OpenClaw + QQ，激活你的第一个 AI 助手',
    tag: '腾讯云文章',
    url: 'https://cloud.tencent.com/developer/article/2625147',
    summary: '更偏入门向，适合想先把 OpenClaw 跟 QQ 接起来、快速跑通第一个聊天入口的用户。'
  },
  {
    title: '让 OpenClaw 接入微信？',
    tag: '腾讯云文章',
    url: 'https://cloud.tencent.com/developer/article/2626045',
    summary: '围绕微信接入思路展开，适合把 OpenClaw 进一步接到日常高频沟通工具里的用户。'
  },
  {
    title: 'OpenClaw 接入飞书：从入门到高效使用',
    tag: '腾讯云文章',
    url: 'https://cloud.tencent.com/developer/article/2626151',
    summary: '偏办公协作场景，适合想把 OpenClaw 用在团队通知、流程协作和企业沟通里的用户。'
  },
  {
    title: 'OpenClaw × 钉钉：让 AI 助手 7×24 小时在线值守',
    tag: '腾讯云文章',
    url: 'https://cloud.tencent.com/developer/article/2626553',
    summary: '偏企业和值守场景，适合关注钉钉接入、自动提醒和长期在线能力的用户。'
  }
];

const localLinks = [
  {
    title: '7 步教程',
    url: withBase('/docs/'),
    summary: '从安装到上手的中文整理版教程。'
  },
  {
    title: '功能页面',
    url: withBase('/features/'),
    summary: '用于展示能力、使用场景和卖点说明。'
  },
  {
    title: '案例演示',
    url: withBase('/cases/'),
    summary: '放现场演示、使用案例和典型流程。'
  },
  {
    title: '上门服务',
    url: withBase('/service/'),
    summary: '长沙本地安装、调试和教学服务说明。'
  }
];
---

<MarketingLayout
  title="OpenClaw 资源导航"
  description="把 OpenClaw 官方站点、腾讯 SkillHub、精选文章和站内入口集中到一个页面，少走弯路。"
>
  <main class="container">
    <section class="hero split-hero">
      <div class="hero-grid">
        <article class="hero-copy">
          <span class="eyebrow">资源导航</span>
          <h1>官方入口、SkillHub、精选文章，统一从这里进入。</h1>
          <p class="lead">
            需要官网、文档、技能和补充文章时，直接从这里进。
          </p>
          <div class="hero-actions">
            <a class="cta cta-primary" href="https://openclaw.ai/" target="_blank" rel="noreferrer">
              先看官网
            </a>
            <a class="cta cta-secondary" href="https://docs.openclaw.ai/" target="_blank" rel="noreferrer">
              打开官方文档
            </a>
            <a class="cta cta-secondary" href="https://skillhub.tencent.com/" target="_blank" rel="noreferrer">
              打开 SkillHub
            </a>
          </div>
          <div class="hero-list">
            <div>
              <strong>安装入口</strong>
              官网和官方文档分开列出，先看介绍，再查操作步骤。
            </div>
            <div>
              <strong>技能入口</strong>
              技能统一跳转到 SkillHub，不在本站单独做技能市场。
            </div>
            <div>
              <strong>更新入口</strong>
              GitHub 仓库和 Releases 适合看版本变化与社区动态。
            </div>
          </div>
        </article>

        <aside class="panel">
          <h2>使用建议</h2>
          <p>建议顺序：官网 -> 文档 -> SkillHub -> GitHub。</p>
          <ul class="bullet-list">
            <li><strong>先了解：</strong> 用官网快速判断它适不适合你的场景</li>
            <li><strong>再安装：</strong> 具体步骤、配置细节以官方文档为准</li>
            <li><strong>后扩展：</strong> 需要新能力时再去 SkillHub 找合适的技能</li>
            <li><strong>再跟新：</strong> 升级前看 Releases，排错时看 GitHub Issue</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <span class="eyebrow">官方站点</span>
          <h2>按用途分好类，直接点进去就行</h2>
        </div>
        <p>优先放官方入口，减少找错站。</p>
      </div>
      <div class="resource-grid">
        {officialLinks.map((item) => (
          <article class="resource-card">
            <div class="resource-head">
              <span class="site-tag">{item.tag}</span>
              <h3>{item.title}</h3>
            </div>
            <p>{item.summary}</p>
            <p class="resource-note">{item.note}</p>
            <a class="resource-link" href={item.url} target="_blank" rel="noreferrer">
              打开站点
              <span>{item.url.replace(/^https?:\/\//, '')}</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <span class="eyebrow">精选中文文章</span>
          <h2>补充一些值得收藏的实战教程</h2>
        </div>
        <p>适合补充看具体接入场景。</p>
      </div>
      <div class="article-grid">
        {articleLinks.map((item) => (
          <article class="article-card">
            <span class="site-tag article-tag">{item.tag}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <a class="article-link" href={item.url} target="_blank" rel="noreferrer">
              查看文章
              <span>cloud.tencent.com</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="spotlight">
        <article class="section-card">
          <span class="eyebrow">站内入口</span>
          <h2>站内内容也能从这里继续看。</h2>
          <div class="mini-grid">
            {localLinks.map((item) => (
              <a class="mini-card" href={item.url}>
                <strong>{item.title}</strong>
                <span>{item.summary}</span>
              </a>
            ))}
          </div>
        </article>
        <article class="section-card">
          <span class="eyebrow">小提醒</span>
          <h2>不要把第三方教程当成唯一依据。</h2>
          <p>
            安装、授权和技能相关内容，优先以官方文档为准。
          </p>
          <div class="hero-actions">
            <a class="cta cta-primary" href={withBase('/docs/')}>看中文教程</a>
            <a class="cta cta-secondary" href={withBase('/contact/')}>联系与更新</a>
          </div>
        </article>
      </div>
    </section>

    <footer class="footer">后面还要补资源时，继续往这页加分组就行。</footer>
  </main>

  <style>
    .resource-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .resource-card {
      display: grid;
      gap: 14px;
      padding: 24px;
      border: 1px solid rgba(126, 72, 42, 0.14);
      border-radius: var(--radius-xl);
      background:
        radial-gradient(circle at top right, rgba(239, 143, 71, 0.12), transparent 30%),
        linear-gradient(180deg, rgba(255, 252, 247, 0.96), rgba(255, 248, 241, 0.88));
      box-shadow: var(--shadow);
    }

    .resource-head {
      display: grid;
      gap: 10px;
    }

    .resource-head h3 {
      font-size: 1.7rem;
    }

    .site-tag {
      width: fit-content;
      padding: 7px 12px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-deep);
      font-size: 0.85rem;
      font-weight: 800;
      letter-spacing: 0.03em;
    }

    .resource-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.8;
    }

    .resource-note {
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 248, 241, 0.88);
      border: 1px solid rgba(217, 94, 57, 0.12);
    }

    .resource-link {
      display: grid;
      gap: 4px;
      width: fit-content;
      padding: 14px 18px;
      border-radius: 18px;
      color: #fff8f4;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      box-shadow: 0 18px 32px rgba(217, 94, 57, 0.18);
      transition: transform 180ms ease;
      font-weight: 800;
    }

    .resource-link:hover {
      transform: translateY(-2px);
    }

    .resource-link span {
      font-size: 0.85rem;
      font-weight: 600;
      opacity: 0.86;
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      margin-top: 16px;
    }

    .article-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .article-card {
      display: grid;
      gap: 14px;
      padding: 24px;
      border-radius: var(--radius-xl);
      border: 1px solid rgba(126, 72, 42, 0.14);
      background:
        radial-gradient(circle at top left, rgba(217, 94, 57, 0.08), transparent 28%),
        linear-gradient(180deg, rgba(255, 251, 246, 0.96), rgba(255, 245, 236, 0.88));
      box-shadow: var(--shadow);
    }

    .article-card h3 {
      font-size: 1.5rem;
    }

    .article-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.8;
    }

    .article-tag {
      background: rgba(141, 52, 36, 0.1);
    }

    .article-link {
      display: grid;
      gap: 4px;
      width: fit-content;
      padding: 13px 17px;
      border-radius: 18px;
      background: rgba(255, 248, 241, 0.92);
      border: 1px solid rgba(217, 94, 57, 0.14);
      color: var(--accent-deep);
      font-weight: 800;
      transition:
        transform 180ms ease,
        border-color 180ms ease;
    }

    .article-link:hover {
      transform: translateY(-2px);
      border-color: rgba(217, 94, 57, 0.24);
    }

    .article-link span {
      font-size: 0.84rem;
      color: var(--muted);
      font-weight: 600;
    }

    .mini-card {
      display: grid;
      gap: 8px;
      padding: 18px;
      border-radius: 20px;
      background: rgba(255, 248, 241, 0.86);
      border: 1px solid rgba(217, 94, 57, 0.12);
      transition:
        transform 180ms ease,
        border-color 180ms ease;
    }

    .mini-card:hover {
      transform: translateY(-2px);
      border-color: rgba(217, 94, 57, 0.2);
    }

    .mini-card strong {
      color: var(--accent-deep);
    }

    .mini-card span {
      color: var(--muted);
      line-height: 1.7;
    }

    @media (max-width: 960px) {
      .resource-grid,
      .article-grid,
      .mini-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MarketingLayout>
