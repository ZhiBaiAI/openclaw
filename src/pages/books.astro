---
import { basename, extname } from 'node:path';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { breadcrumbSchema, collectionPageSchema, itemListSchema } from '../data/seo.mjs';

type BookItem = {
  title: string;
  filename: string;
  href: string;
  id: string;
};

const slugify = (value: string) =>
  value
    .normalize('NFKD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
    .replace(/^-+|-+$/g, '') || 'book';

const bookModules = import.meta.glob('../book/*', { eager: true, import: 'default' });

const books = Object.entries(bookModules)
  .map(([modulePath, assetUrl], index) => {
    if (typeof assetUrl !== 'string') return null;

    const filename = modulePath.split('/').pop() ?? modulePath;
    const extension = extname(filename);
    const title = basename(filename, extension).replace(/_/g, ' ').trim() || filename;

    return {
      title,
      filename,
      href: assetUrl,
      id: `${slugify(title)}-${index + 1}`
    } satisfies BookItem;
  })
  .filter((book): book is BookItem => Boolean(book))
  .sort((left, right) => left.title.localeCompare(right.title, 'zh-CN'));

const bookKeywords = [
  'OpenClaw 电子书下载',
  'OpenClaw 资料下载',
  '电子书下载页',
  'PDF 下载',
  'OpenClaw 手册'
];

const bookStructuredData = [
  collectionPageSchema({
    site: Astro.site,
    path: '/books/',
    name: '电子书下载',
    description: '集中整理站内电子书与资料下载入口，文件来自 src/book 目录。',
    keywords: bookKeywords,
    about: ['电子书下载', '资料下载', 'OpenClaw 手册']
  }),
  itemListSchema({
    site: Astro.site,
    path: '/books/',
    name: '电子书下载列表',
    items: books.map((book) => ({
      name: book.title,
      path: `/books/#${book.id}`
    }))
  }),
  breadcrumbSchema(Astro.site, [
    { name: '首页', path: '/' },
    { name: '电子书下载', path: '/books/' }
  ])
];
---

<MarketingLayout
  title="电子书下载 | 虾客AI"
  description="集中整理放在 src/book 目录下的电子书与资料，进入页面即可直接下载。"
  keywords={bookKeywords}
  structuredData={bookStructuredData}
>
  <main class="page" id="main-content">
    <div class="container books-page">
      <h1 class="books-title">电子书下载</h1>

      {
        books.length > 0 ? (
          <section class="books-list" aria-label="电子书列表">
            {books.map((book) => (
              <article class="book-item" id={book.id}>
                <h2 class="book-item__title">{book.title}</h2>
                <a class="button button-primary" href={book.href} download={book.filename}>下载</a>
              </article>
            ))}
          </section>
        ) : (
          <article class="summary-card books-empty">
            <p>暂无可下载电子书。</p>
          </article>
        )
      }
    </div>
  </main>

  <style>
    .books-page {
      display: grid;
      gap: 1rem;
    }

    .books-title {
      margin: 0;
      padding: 0 2px;
      font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    }

    .books-list {
      display: grid;
      gap: 12px;
    }

    .book-item {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 12px;
      align-items: center;
      padding: 16px 18px;
      border: 1px solid var(--line);
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(250, 245, 239, 0.94));
      box-shadow: 0 10px 24px rgba(73, 52, 38, 0.05);
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        box-shadow 180ms ease;
    }

    .book-item:hover,
    .book-item:focus-within {
      transform: translateY(-1px);
      border-color: rgba(186, 99, 54, 0.18);
      box-shadow: 0 12px 26px rgba(73, 52, 38, 0.08);
    }

    .book-item__title {
      margin: 0;
      font-size: clamp(1.05rem, 2vw, 1.28rem);
      line-height: 1.24;
    }

    .books-empty {
      padding: 20px;
    }

    .books-empty p {
      margin: 0;
    }

    @media (max-width: 640px) {
      .book-item,
      .books-empty {
        padding: 16px;
      }

      .book-item {
        grid-template-columns: 1fr;
      }

      .book-item .button {
        width: 100%;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .book-item {
        transition: none;
      }
    }
  </style>
</MarketingLayout>
