---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const supportDevices = ['Windows 电脑', 'macOS 电脑', 'Linux / 云服务器', '旧主机 / 小型常驻设备'];
const serviceItems = [
  ['交付前沟通', '先确认设备、使用场景、聊天入口和你最想先跑通的能力。'],
  ['部署与调试', '完成环境配置、模型接入、聊天渠道、基础调试和功能验证。'],
  ['案例演示', '根据你的实际用途做 1 到 2 个小案例现场演示，避免装完不会用。'],
  ['文档与支持', '交付后继续通过站内文档、资源导航、命令速查和支持页维护使用。']
];
---

<MarketingLayout
  title="OpenClaw 交付服务"
  description="把交付范围、支持设备、服务流程和交付后支持方式集中说明，方便客户判断是否适合。"
>
  <main class="container">
    <section class="hero split-hero">
      <div class="hero-grid">
        <article class="hero-copy">
          <span class="eyebrow">交付服务</span>
          <h1>上门或远程都可以，但目标始终是交付一个真正能用的助手。</h1>
          <p class="lead">
            先沟通需求，再部署调试，最后用案例带你上手。
          </p>
          <div class="hero-actions">
            <a class="cta cta-primary" href={withBase('/contact/')}>看交付支持</a>
            <a class="cta cta-secondary" href={withBase('/cases/')}>看真实案例</a>
          </div>
        </article>

        <aside class="panel">
          <h2>支持设备</h2>
          <ul class="bullet-list">
            {supportDevices.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <span class="eyebrow">交付内容</span>
          <h2>交付不是一次性安装，而是一套清晰流程</h2>
        </div>
        <p>先跑通真实场景，再慢慢扩功能。</p>
      </div>
      <div class="card-grid">
        {serviceItems.map(([title, text]) => (
          <article class="section-card">
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="spotlight">
        <article class="section-card">
          <span class="eyebrow">适合的客户</span>
          <ul>
            <li>想把 OpenClaw 用进真实工作和生活流程，而不是只停留在尝鲜阶段</li>
            <li>不想自己从零排坑，想直接拿到能用的部署方案</li>
            <li>希望交付后还有文档、案例和支持入口可持续使用</li>
          </ul>
        </article>
        <article class="section-card">
          <span class="eyebrow">交付原则</span>
          <ul>
            <li>优先跑通 1 到 2 个最贴近你需求的实际场景</li>
            <li>高风险能力默认保守，不做无边界放权</li>
            <li>交付后仍以站内文档和支持入口做长期维护</li>
          </ul>
        </article>
      </div>
    </section>
  </main>
</MarketingLayout>
