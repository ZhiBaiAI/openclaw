---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const routes = [
  {
    id: 'self-install',
    tag: '自己上手',
    title: '我想自己安装，但希望路线清楚一点',
    summary: '适合愿意自己折腾，但不想从一堆零散教程里拼流程的人。',
    bullets: ['先走文档教程的 7 步流程', '遇到问题先查命令速查和 FAQ', '需要外部资料时再去资源导航']
  },
  {
    id: 'delivery',
    tag: '交付服务',
    title: '我想尽快用起来，直接找你做交付',
    summary: '适合没时间自己踩坑，或者已经知道自己不会配环境、不会接聊天入口的人。',
    bullets: ['先说明设备和想用的场景', '优先跑通 1 到 2 个真实需求', '交付后继续保留文档和支持入口']
  },
  {
    id: 'daily-use',
    tag: '日常使用',
    title: '我已经在用了，想排错或继续扩展',
    summary: '适合已交付用户和已经跑起来的用户，把这里当成支持和回看入口。',
    bullets: ['先自查教程、命令和 FAQ', '再带着现象和日志来沟通', '需要案例或外部资源时直接跳转对应入口']
  }
];

const deliverySteps = [
  ['确认设备与入口', '先确认你准备使用的设备、聊天入口和优先场景，不做无效安装。'],
  ['跑通最小可用版本', '优先把一个聊天入口、一个模型和一两个真实场景跑顺。'],
  ['现场教你怎么用', '不是只装完就走，而是会带着你实际走一遍。'],
  ['后续继续支持', '交付完成后，文档、命令速查、案例和支持方式仍然可以继续配合使用。']
];

const selfInstall = [
  '先进入文档教程，把 7 步流程从头看一遍。',
  '遇到命令、配置或接入问题，先查常用命令速查和 FAQ。',
  '需要找官网、官方文档、SkillHub 或版本更新，再去资源导航。'
];

const serviceScope = [
  '环境安装与基础配置',
  '模型接入与聊天入口接入',
  '基础规则整理与使用方式说明',
  '1 到 2 个真实场景演示',
  '交付后继续通过本站回看和排错'
];

const supportChecklist = [
  '你的设备类型和系统',
  '你现在最想先跑通的 1 到 2 个场景',
  '已经接入或准备接入的聊天工具',
  '如果报错，尽量附上截图、现象和日志'
];

const introFacts = [
  ['3 条路线', '自己安装、直接交付、继续排错三类用户分开看。'],
  ['先跑最小可用版本', '不追求一次堆满功能，先把一个入口跑顺。'],
  ['联系前先备信息', '设备、场景、聊天入口和报错现象越清楚越省时间。']
];
---

<MarketingLayout
  title="虾客AI 安装交付服务"
  description="适合想自己安装、预约交付或在使用中需要支持的用户。"
>
  <main class="page" id="main-content">
    <div class="container">
      <section class="page-intro">
        <div class="page-intro__grid">
          <article class="page-intro__content">
            <span class="eyebrow">安装交付服务</span>
            <h1>自己安装、预约交付、使用支持，都可以先从这里开始。</h1>
            <p class="lead">
              不管你是准备自己动手、希望我直接帮你交付，还是已经在使用中遇到问题，这一页都会先告诉你该走哪条路、要准备什么、下一步去哪里。
            </p>
            <div class="action-row">
              <a class="button button-primary" href="#self-install">自己安装路线</a>
              <a class="button button-secondary" href="#delivery">交付服务说明</a>
              <a class="button button-secondary" href="#contact">支持与联系</a>
            </div>
            <div class="intro-facts">
              {introFacts.map(([title, text]) => (
                <article class="intro-fact">
                  <strong>{title}</strong>
                  <span>{text}</span>
                </article>
              ))}
            </div>
          </article>

          <aside class="page-intro__aside">
            <span class="section-kicker">适合谁</span>
            <ul class="simple-list">
              <li>新客户先判断自己装还是找我做交付。</li>
              <li>希望少走弯路，先按一条稳定路线安装的人。</li>
              <li>已经在使用，想继续排错或扩展的人。</li>
            </ul>
          </aside>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <div>
            <span class="section-kicker">三条路线</span>
            <h2>先判断自己在哪一类，再继续往下走。</h2>
          </div>
          <p class="section-copy">
            不用一上来就看很长的说明。先找到自己的路线，后面的内容才真正有用。
          </p>
        </div>

        <div class="directory-list">
          {routes.map((item) => (
            <a class="directory-row" href={`#${item.id}`}>
              <div class="directory-row__main">
                <span class="card-tag">{item.tag}</span>
                <h3 class="directory-row__title">{item.title}</h3>
                <p class="directory-row__summary">{item.summary}</p>
              </div>
              <div class="directory-row__meta">
                <ul class="directory-inline-list">
                  {item.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </div>
              <div class="directory-row__action">
                <span class="button button-secondary">查看路线</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="section section-anchor" id="self-install">
        <div class="split-grid">
          <article class="summary-card">
            <span class="section-kicker">自己安装路线</span>
            <h2>适合愿意自己动手，但不想迷路的人。</h2>
            <ul class="bullet-list">
              {selfInstall.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="action-row">
              <a class="button button-primary" href={withBase('/docs/')}>进入文档教程</a>
              <a class="button button-secondary" href={withBase('/links/')}>补外部资源</a>
            </div>
          </article>

          <article class="note-card">
            <span class="status-chip">建议顺序</span>
            <h3 class="card-title">不要同时开十几个入口。</h3>
            <p class="card-meta">
              初次上手最容易犯的错，是一边翻官方文档、一边看第三方文章、一边到处问人，最后步骤反而乱掉。建议顺序是：本站教程优先，外部资料按需补充。
            </p>
          </article>
        </div>
      </section>

      <section class="section section-anchor" id="delivery">
        <div class="section-header">
          <div>
            <span class="section-kicker">交付服务</span>
            <h2>如果你看过还是觉得自己不会，直接走交付会更省时间。</h2>
          </div>
          <p class="section-copy">
            重点不是帮你“装一个程序”，而是让你真的能开始用，并且后续还能自己继续维护和扩展。
          </p>
        </div>

        <div class="card-grid">
          {deliverySteps.map(([title, text]) => (
            <article class="info-card">
              <h3 class="card-title">{title}</h3>
              <p class="card-meta">{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="split-grid">
          <article class="summary-card">
            <span class="section-kicker">通常会覆盖什么</span>
            <h2>交付不是一次性装完，而是把最小可用流程带起来。</h2>
            <ul class="bullet-list">
              {serviceScope.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>

          <article class="note-card">
            <span class="status-chip support">边界提醒</span>
            <h3 class="card-title">先把一两个场景养熟，比一口气堆很多功能更重要。</h3>
            <p class="card-meta">
              真正能长期用下去的 OpenClaw，不是功能越多越好，而是入口稳定、规则清楚、你知道每天怎么用，出了问题也知道怎么查。
            </p>
          </article>
        </div>
      </section>

      <section class="section section-anchor" id="daily-use">
        <div class="section-header">
          <div>
            <span class="section-kicker">已经在使用</span>
            <h2>已经用起来后，先按这几个入口继续排查和补充。</h2>
          </div>
          <p class="section-copy">
            建议先自查，再沟通。这样排错更快，也更容易把真正的问题说清楚。
          </p>
        </div>

        <div class="mini-grid">
          <a class="mini-card" href={withBase('/docs/')}>
            <strong>先回文档教程</strong>
            <span>重新梳理 7 步流程，很多问题都出在顺序没走对。</span>
          </a>
          <a class="mini-card" href={withBase('/docs/reference/common-commands/')}>
            <strong>看常用命令速查</strong>
            <span>命令、状态检查、重启与日志查询，先从这里查。</span>
          </a>
          <a class="mini-card" href={withBase('/cases/')}>
            <strong>补看案例</strong>
            <span>很多扩展思路，都是从具体案例里长出来的。</span>
          </a>
          <a class="mini-card" href={withBase('/links/')}>
            <strong>补外部资源</strong>
            <span>官网、SkillHub、Releases 和外部文章都集中在一页。</span>
          </a>
        </div>
      </section>

      <section class="section section-anchor" id="contact">
        <div class="split-grid support-grid">
          <article class="summary-card">
            <span class="section-kicker">联系前准备</span>
            <h2>把这些信息准备好，沟通会顺很多。</h2>
            <ul class="bullet-list">
              {supportChecklist.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>

          <article class="note-card qr-card">
            <span class="section-kicker">支持与联系</span>
            <h3 class="card-title">需要预约交付或继续排错，直接扫码联系。</h3>
            <img
              src={withBase('/wechat-qr.png')}
              alt="微信联系二维码"
              width="549"
              height="542"
              loading="lazy"
              decoding="async"
            />
            <p class="card-meta">
              添加时备注你的设备类型、当前阶段，以及最想先解决的事情，会更容易快速对上问题。
            </p>
          </article>
        </div>
      </section>
    </div>
  </main>

  <style>
    .section-anchor {
      scroll-margin-top: 92px;
    }

    .qr-card img {
      width: min(100%, 220px);
      height: auto;
      aspect-ratio: 549 / 542;
      margin-top: 18px;
      border-radius: 24px;
      border: 1px solid rgba(193, 94, 42, 0.12);
      background: rgba(255, 251, 244, 0.92);
      padding: 12px;
      box-shadow: 0 16px 32px rgba(83, 58, 42, 0.08);
    }

    .support-grid {
      align-items: start;
    }
  </style>
</MarketingLayout>
