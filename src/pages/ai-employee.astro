---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import {
  breadcrumbSchema,
  collectionPageSchema,
  itemListSchema
} from '../data/seo.mjs';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;
const contactQrSrc = withBase('/wechat-qr.png');

const introFacts = [
  ['2-4 周试点', '先跑通一个岗位。'],
  ['多入口接入', '聊天入口与业务系统统一接入。'],
  ['可治理上线', '权限、审批、审计、回滚同步配置。']
];

const integrationBands = [
  {
    title: '沟通入口',
    items: ['企业微信', '飞书', '钉钉', '邮件']
  },
  {
    title: '业务系统',
    items: ['CRM', '表格 / 多维表', '知识库', '审批流', '文件系统', '日历']
  },
  {
    title: '控制能力',
    items: ['权限', '审批', '审计', '灰度', '回滚', '成本控制']
  }
];

const roleGroups = [
  {
    id: 'finance',
    label: '财务后台',
    eyebrow: '财务与报销',
    title: '覆盖报销、对账、归档、报表这些高频后台动作。',
    description: '单据更快，核对更稳。',
    roles: ['发票与单据专员', '费用报销审核助理', '应收应付对账专员', '财务报表助理'],
    inputs: ['邮箱发票', '报销单据', '对账表', '财务规则'],
    outputs: ['归档清单', '异常提醒', '复核意见', '标准台账'],
    signal: ['月末集中处理压力大', '单据来源分散', '人工重复录入多']
  },
  {
    id: 'sales',
    label: '销售增长',
    eyebrow: '销售与线索',
    title: '让线索分层、报价整理、会后推进形成统一节奏。',
    description: '减少漏跟进与漏记录。',
    roles: ['线索清洗专员', '销售跟进助理', '报价与方案助理', '续费与流失预警专员'],
    inputs: ['线索表单', '聊天记录', '报价模板', '客户阶段'],
    outputs: ['线索分层', '跟进清单', '报价草案', '续费预警'],
    signal: ['线索多但跟进不齐', '会后动作容易断', '客户状态记录不完整']
  },
  {
    id: 'support',
    label: '客服交付',
    eyebrow: '客服与工单',
    title: '统一接待、分流、标准回复与工单升级流程。',
    description: '响应更快，一致性更高。',
    roles: ['全渠道客服专员', '工单分流专员', '售后回访助理', '知识库问答助理'],
    inputs: ['客服话术', '工单规则', '知识库', '售后流程'],
    outputs: ['问题分类', '标准回复', '升级建议', '回访摘要'],
    signal: ['渠道太多', '重复问题太多', '人工分流成本高']
  },
  {
    id: 'hr',
    label: '人事行政',
    eyebrow: '人事与行政',
    title: '让招聘筛选、入职协同、行政流转更轻更快。',
    description: '提醒、整理、核对自动完成。',
    roles: ['招聘筛选专员', '面试协同助理', '入职与档案管理员', '考勤与排班助理'],
    inputs: ['岗位 JD', '候选人简历', '入职材料', '排班规则'],
    outputs: ['筛选结论', '排期建议', '档案清单', '异常提醒'],
    signal: ['流程碎片化', '资料核对繁琐', '提醒依赖人工']
  },
  {
    id: 'content',
    label: '内容运营',
    eyebrow: '内容与运营',
    title: '覆盖选题、评论沉淀、日报复盘这些重复运营动作。',
    description: '收集、整理、改写与提醒统一处理。',
    roles: ['内容选题研究员', '评论与私信沉淀助理', '运营日报助理', 'SOP 巡检助理'],
    inputs: ['评论与私信', '选题池', '日报模板', 'SOP'],
    outputs: ['选题建议', '问题归类', '日报草稿', '巡检结果'],
    signal: ['内容重复劳动多', '反馈没有沉淀', '日报复盘容易拖']
  }
];

const rolloutSteps = [
  ['01 选岗位', '明确输入、输出与验收标准。'],
  ['02 接入口', '接入聊天入口、知识与业务系统。'],
  ['03 设规则', '配置权限、审批与人工接管。'],
  ['04 灰度上线', '小范围投产后复制扩编。']
];

const governanceCards = [
  {
    title: '可交付',
    summary: '输出统一，方便复核与留档。',
    bullets: ['明确输出模板', '保留上下文来源', '把验收口径写进流程']
  },
  {
    title: '可治理',
    summary: '权限、审批、知识边界统一控制。',
    bullets: ['角色权限分层', '高风险动作先审批', '超边界自动转人工']
  },
  {
    title: '可验证',
    summary: '持续跟踪效率、正确率与人工介入。',
    bullets: ['处理时长', '命中率 / 正确率', '人工介入比例']
  },
  {
    title: '可运维',
    summary: '质量、成本、稳定性与版本持续可见。',
    bullets: ['监控告警', '灰度发布与回滚', '日志审计与定位']
  }
];

const deploymentCards = [
  {
    title: '部署方式',
    items: ['私有化部署（内网）', '专有云部署（VPC）', '混合部署（敏感本地，通用云端）']
  },
  {
    title: '可替换组件',
    items: ['模型服务', '向量检索与存储', '日志与审计系统']
  },
  {
    title: '运维能力',
    items: ['资源与成本控制', '灰度、回滚、版本管理', '稳定性监控与故障定位']
  }
];

const modelCards = [
  {
    title: '按任务路由模型',
    summary: '不同任务自动匹配不同模型，兼顾速度、质量和成本。'
  },
  {
    title: '敏感任务单独看边界',
    summary: '财务、人事、审批和对外承诺类任务独立配置安全边界和复核策略。'
  },
  {
    title: '先看结果，再谈型号',
    summary: '选择标准围绕稳定性、响应速度、成本和可控性展开。'
  }
];

const startModes = [
  {
    tag: '先试点',
    title: '从 1 个岗位开始',
    summary: '先验证一个岗位闭环。',
    bullets: ['投入小', '验证快', '风险低']
  },
  {
    tag: '再扩编',
    title: '按团队复制',
    summary: '把岗位模板复制到团队。',
    bullets: ['复制模板', '统一规则', '多团队管理']
  },
  {
    tag: '做交付',
    title: '按 SOP 定制上线',
    summary: '围绕 SOP 完成接入与验收交付。',
    bullets: ['项目交付', '系统接入', '按验收推进']
  }
];

const finalCtaTraits = [
  ['岗位清晰', '输入、输出和验收口径明确'],
  ['入口固定', '聊天入口或业务系统已经在用'],
  ['节奏可控', '适合先试点，再逐步扩编']
];

const aiEmployeeKeywords = [
  'OpenClaw AI 员工',
  'AI 员工解决方案',
  'OpenClaw 岗位型 Agent',
  'AI 员工 试点',
  'AI 员工 部署',
  'AI 员工 上线'
];

const aiEmployeeStructuredData = [
  collectionPageSchema({
    site: Astro.site,
    path: '/ai-employee/',
    name: 'AI 员工解决方案',
    description: '围绕岗位、入口、规则、治理与上线方式，展示 AI 员工解决方案。',
    keywords: aiEmployeeKeywords,
    about: ['AI 员工', '岗位型 Agent', 'OpenClaw 落地', 'Agent 治理']
  }),
  itemListSchema({
    site: Astro.site,
    path: '/ai-employee/',
    name: 'AI 员工页面导航',
    items: [
      { name: '岗位方案', path: '/ai-employee/#roles' },
      { name: '上线路径', path: '/ai-employee/#rollout' },
      { name: '部署与模型', path: '/ai-employee/#deployment' },
      { name: '开始方式', path: '/ai-employee/#start' }
    ]
  }),
  breadcrumbSchema(Astro.site, [
    { name: '首页', path: '/' },
    { name: 'AI 员工', path: '/ai-employee/' }
  ])
];
---

<MarketingLayout
  title="AI 员工解决方案 | 虾客AI"
  description="围绕岗位、入口、规则、治理与上线方式，展示面向团队与企业的 AI 员工产品与交付方案。"
  keywords={aiEmployeeKeywords}
  structuredData={aiEmployeeStructuredData}
>
  <main class="page" id="main-content">
    <div class="container employee-page">
      <section class="page-intro employee-hero">
        <div class="page-intro__grid employee-hero__grid">
          <article class="page-intro__content employee-hero__content">
            <span class="eyebrow">AI 员工解决方案</span>
            <h1>先让一个岗位稳定上岗，再把整支团队一点点替你跑起来。</h1>
            <p class="lead">
              让 AI 员工进入你的业务入口，接手高频流程，稳定输出结果，并在关键节点保留人工控制权。
            </p>
            <div class="action-row">
              <button
                class="button button-primary"
                type="button"
                data-contact-open
                aria-haspopup="dialog"
                aria-controls="employee-contact-dialog"
              >
                获取 AI 员工
              </button>
              <a class="button button-secondary" href="#roles">选择岗位方案</a>
              <a class="button button-secondary" href="#rollout">查看上线路径</a>
            </div>
            <div class="intro-facts">
              {introFacts.map(([title, text]) => (
                <article class="intro-fact">
                  <strong>{title}</strong>
                  <span>{text}</span>
                </article>
              ))}
            </div>
          </article>

          <aside class="page-intro__aside employee-cockpit">
            <div class="employee-cockpit__top">
              <span class="status-chip support">试点方案</span>
              <strong>从一个清晰岗位启动，最快看到可落地的结果。</strong>
            </div>
            <div class="employee-cockpit__board">
              <article class="employee-cockpit__item">
                <span>优先岗位</span>
                <b>报销审核 / 工单分流 / 销售跟进 / 招聘筛选</b>
              </article>
              <article class="employee-cockpit__item">
                <span>接入入口</span>
                <b>企业微信、飞书、邮件、CRM、表格、知识库</b>
              </article>
              <article class="employee-cockpit__item">
                <span>上线控制</span>
                <b>权限、审批、审计、回滚、人工接管</b>
              </article>
            </div>
            <div class="employee-cockpit__cta">
              <p class="employee-cockpit__hint">想直接开始，先扫码联系，按你的业务入口给出试点建议。</p>
              <button
                class="button button-primary employee-cockpit__button"
                type="button"
                data-contact-open
                aria-haspopup="dialog"
                aria-controls="employee-contact-dialog"
              >
                立即获取 AI 员工
              </button>
              <a class="employee-cockpit__link" href={withBase('/cases/')}>查看行业案例</a>
            </div>
          </aside>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <div>
            <span class="section-kicker">支持接入</span>
            <h2>直接接入现有入口与系统。</h2>
          </div>
          <p class="section-copy">入口、系统与控制能力统一接入。</p>
        </div>

        <div class="employee-integration-strip">
          {integrationBands.map((group) => (
            <article class="employee-integration-band">
              <strong>{group.title}</strong>
              <div class="employee-integration-band__items">
                {group.items.map((item) => (
                  <span class="employee-brand-pill">{item}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="roles" data-tabs-root>
        <div class="section-header">
          <div>
            <span class="section-kicker">岗位方案</span>
            <h2>选择最适合率先上线的岗位。</h2>
          </div>
          <p class="section-copy">
            从一个高频岗位开始。
          </p>
        </div>

        <div class="employee-role-tabs" role="tablist" aria-label="AI 员工岗位分类">
          {roleGroups.map((group, index) => (
            <button
              class:list={['employee-role-tabs__button', index === 0 && 'is-active']}
              id={`role-tab-${group.id}`}
              type="button"
              role="tab"
              aria-controls={`role-panel-${group.id}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
              data-tab-target={group.id}
            >
              <span class="employee-role-tabs__label">{group.label}</span>
              <span class="employee-role-tabs__eyebrow">{group.eyebrow}</span>
            </button>
          ))}
        </div>

        <div class="employee-role-panels">
          {roleGroups.map((group, index) => (
            <section
              class:list={['employee-role-panel', index === 0 && 'is-active']}
              id={`role-panel-${group.id}`}
              role="tabpanel"
              aria-labelledby={`role-tab-${group.id}`}
              data-tab-panel={group.id}
              hidden={index !== 0}
            >
              <div class="employee-role-panel__hero">
                <div class="employee-role-panel__copy">
                  <span class="card-tag">{group.eyebrow}</span>
                  <h3>{group.title}</h3>
                  <p>{group.description}</p>
                </div>
                <div class="employee-role-panel__signals">
                  {group.signal.map((item) => (
                    <span class="case-signal">{item}</span>
                  ))}
                </div>
              </div>

              <div class="employee-role-panel__grid">
                <article class="panel-detail-card">
                  <strong>可上岗角色</strong>
                  <ul class="bullet-list">
                    {group.roles.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </article>
                <article class="panel-detail-card">
                  <strong>常见输入</strong>
                  <ul class="bullet-list">
                    {group.inputs.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </article>
                <article class="panel-detail-card">
                  <strong>可交付结果</strong>
                  <ul class="bullet-list">
                    {group.outputs.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </article>
              </div>
            </section>
          ))}
        </div>
      </section>

      <section class="section" id="rollout">
        <div class="section-header">
          <div>
            <span class="section-kicker">上线路径</span>
            <h2>四步完成试点、上线与扩编。</h2>
          </div>
          <p class="section-copy">
            统一标准，逐步复制。
          </p>
        </div>

        <div class="employee-rollout">
          {rolloutSteps.map(([title, text], index) => (
            <article class="employee-rollout__step">
              <span class="employee-rollout__index">{String(index + 1).padStart(2, '0')}</span>
              <div class="employee-rollout__body">
              <strong>{title}</strong>
              <p>{text}</p>
              <button
                class="employee-rollout__cta"
                type="button"
                data-contact-open
                aria-haspopup="dialog"
                aria-controls="employee-contact-dialog"
              >
                这一步，直接联系
              </button>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <div>
            <span class="section-kicker">治理与安全</span>
            <h2>高价值岗位上线，治理先行。</h2>
          </div>
          <p class="section-copy">
            关键岗位统一交付、治理、验证与运维标准。
          </p>
        </div>

        <div class="card-grid employee-governance-grid">
          {governanceCards.map((item) => (
            <article class="note-card employee-governance-card">
              <h3 class="card-title">{item.title}</h3>
              <p class="card-meta">{item.summary}</p>
              <ul class="bullet-list">
                {item.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="deployment">
        <div class="section-header">
          <div>
            <span class="section-kicker">部署与模型</span>
            <h2>部署边界、数据边界与模型策略同步确定。</h2>
          </div>
          <p class="section-copy">
            按合规、审计与成本要求配置。
          </p>
        </div>

        <div class="split-grid employee-deployment-grid">
          <article class="summary-card employee-deployment-card">
            <span class="section-kicker">部署清单</span>
            <div class="mini-grid employee-deployment-mini-grid">
              {deploymentCards.map((item) => (
                <div class="mini-card">
                  <strong>{item.title}</strong>
                  <ul class="bullet-list employee-compact-list">
                    {item.items.map((entry) => (
                      <li>{entry}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </article>

          <article class="page-intro__aside employee-model-board">
            <span class="section-kicker">模型策略</span>
            <div class="employee-model-board__list">
              {modelCards.map((item) => (
                <article class="employee-model-board__item">
                  <strong>{item.title}</strong>
                  <p>{item.summary}</p>
                </article>
              ))}
            </div>
          </article>
        </div>
      </section>

      <section class="section" id="start">
        <div class="section-header">
          <div>
            <span class="section-kicker">怎么开始</span>
            <h2>按团队阶段选择启动方式。</h2>
          </div>
          <p class="section-copy">
            试点、复制、定制三种方式。
          </p>
        </div>

        <div class="card-grid employee-start-grid">
          {startModes.map((item) => (
            <article class="info-card employee-start-card">
              <span class="card-tag">{item.tag}</span>
              <h3 class="card-title">{item.title}</h3>
              <p class="card-meta">{item.summary}</p>
              <ul class="directory-inline-list">
                {item.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="split-grid employee-cta-grid">
          <article class="summary-card employee-cta-card">
            <span class="section-kicker">下一步</span>
            <h2>下一步，先把最关键的三件事落下去。</h2>
            <p class="employee-cta-card__lead">
              留下你的业务场景后，我们会按岗位、入口和试点节奏给出更合适的启动建议。
            </p>
            <ul class="bullet-list employee-cta-list">
              <li>选 1 个高频岗位。</li>
              <li>接 1 到 2 个高频入口。</li>
              <li>保留人工复核后再扩编。</li>
            </ul>
            <div class="action-row">
              <button
                class="button button-primary"
                type="button"
                data-contact-open
                aria-haspopup="dialog"
                aria-controls="employee-contact-dialog"
              >
                获取 AI 员工
              </button>
              <a class="button button-secondary" href={withBase('/cases/')}>查看案例</a>
            </div>
          </article>

          <article class="note-card employee-cta-note">
            <span class="status-chip support">优先合作团队</span>
            <h3 class="card-title">岗位明确、入口固定、交付标准清晰的团队。</h3>
            <div class="employee-cta-note__list">
              {finalCtaTraits.map(([title, text]) => (
                <article class="employee-cta-note__item">
                  <strong>{title}</strong>
                  <p>{text}</p>
                </article>
              ))}
            </div>
            <p class="card-meta">
              这类项目上线速度快，试点周期短，也更容易快速复制到更多岗位和团队。
            </p>
          </article>
        </div>
      </section>

      <div
        class="employee-contact-dialog"
        id="employee-contact-dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="employee-contact-title"
        hidden
      >
        <div class="employee-contact-dialog__backdrop" data-contact-close></div>
        <div class="employee-contact-dialog__panel">
          <button
            class="employee-contact-dialog__close"
            type="button"
            aria-label="关闭获取 AI 员工弹层"
            data-contact-close
          >
