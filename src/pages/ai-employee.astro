  <script is:inline>
    (() => {
      const activate = (root, id) => {
        const buttons = Array.from(root.querySelectorAll('[data-tab-target]'));
        const panels = Array.from(root.querySelectorAll('[data-tab-panel]'));
        const fallbackId = buttons[0] && buttons[0].dataset.tabTarget;
        const resolvedId = panels.some((panel) => panel.dataset.tabPanel === id) ? id : fallbackId;

        if (!resolvedId) return;

        buttons.forEach((button) => {
          const active = button.dataset.tabTarget === resolvedId;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-selected', String(active));
          button.tabIndex = active ? 0 : -1;
        });

        panels.forEach((panel) => {
          const active = panel.dataset.tabPanel === resolvedId;
          panel.hidden = !active;
          panel.classList.toggle('is-active', active);
        });
      };

      const initRoot = (root) => {
        const activeButton = root.querySelector('[data-tab-target].is-active');
        activate(root, activeButton && activeButton.dataset.tabTarget);
      };

      const handleClick = (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const button = target.closest('[data-tab-target]');
        if (!(button instanceof HTMLButtonElement)) return;

        const root = button.closest('[data-tabs-root]');
        const id = button.dataset.tabTarget;
        if (!(root instanceof HTMLElement) || !id) return;

        activate(root, id);
      };

      const handleKeydown = (event) => {
        const target = event.target;
        if (!(target instanceof HTMLButtonElement)) return;
        if (!target.matches('[data-tab-target]')) return;
        if (!['ArrowLeft', 'ArrowRight'].includes(event.key)) return;

        const root = target.closest('[data-tabs-root]');
        if (!(root instanceof HTMLElement)) return;

        const buttons = Array.from(root.querySelectorAll('[data-tab-target]')).filter(
          (button) => button instanceof HTMLButtonElement
        );
        const index = buttons.indexOf(target);
        if (index === -1 || !buttons.length) return;

        event.preventDefault();

        const nextIndex =
          event.key === 'ArrowRight'
            ? (index + 1) % buttons.length
            : (index - 1 + buttons.length) % buttons.length;
        const nextButton = buttons[nextIndex];
        const nextId = nextButton && nextButton.dataset.tabTarget;
        if (!nextButton || !nextId) return;

        activate(root, nextId);
        nextButton.focus();
      };

      const initAll = () => {
        document.querySelectorAll('[data-tabs-root]').forEach((root) => {
          if (root instanceof HTMLElement) initRoot(root);
        });
      };

      let lastTrigger = null;

      const getDialog = () => document.getElementById('employee-contact-dialog');
      const getDialogPanel = () => {
        const dialog = getDialog();
        return dialog instanceof HTMLElement ? dialog.querySelector('.employee-contact-dialog__panel') : null;
      };

      const openDialog = (trigger) => {
        const dialog = getDialog();
        if (!(dialog instanceof HTMLElement)) return;
        lastTrigger = trigger instanceof HTMLElement ? trigger : null;
        dialog.hidden = false;
        document.documentElement.classList.add('has-employee-contact-dialog');
        const closeButton = dialog.querySelector('.employee-contact-dialog__close');
        if (closeButton instanceof HTMLElement) closeButton.focus();
      };

      const closeDialog = () => {
        const dialog = getDialog();
        if (!(dialog instanceof HTMLElement)) return;
        dialog.hidden = true;
        document.documentElement.classList.remove('has-employee-contact-dialog');
        if (lastTrigger instanceof HTMLElement) lastTrigger.focus();
      };

      if (!window.__employeeTabsBound) {
        window.__employeeTabsBound = true;
        document.addEventListener('click', handleClick);
        document.addEventListener('keydown', handleKeydown);
        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const openButton = target.closest('[data-contact-open]');
          if (openButton instanceof HTMLElement) {
            openDialog(openButton);
            return;
          }

          const closeButton = target.closest('[data-contact-close]');
          if (closeButton instanceof HTMLElement) {
            closeDialog();
          }
        });
        document.addEventListener('keydown', (event) => {
          const dialog = getDialog();
          if (event.key !== 'Escape') return;
          if (!(dialog instanceof HTMLElement) || dialog.hidden) return;
          closeDialog();
        });
      }

      const bindDialog = () => {
        const dialog = getDialog();
        const dialogPanel = getDialogPanel();
        if (!(dialog instanceof HTMLElement) || !(dialogPanel instanceof HTMLElement)) return;
        if (dialog.dataset.bound === 'true') return;

        dialog.dataset.bound = 'true';
        dialog.addEventListener('click', (event) => {
          if (!(event.target instanceof Node)) return;
          if (!dialogPanel.contains(event.target)) closeDialog();
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener(
          'DOMContentLoaded',
          () => {
            initAll();
            bindDialog();
          },
          { once: true }
        );
      } else {
        initAll();
        bindDialog();
      }

      document.addEventListener('astro:page-load', () => {
        initAll();
        bindDialog();
      });
      document.addEventListener('astro:after-swap', () => {
        initAll();
        bindDialog();
      });
    })();
  </script>

