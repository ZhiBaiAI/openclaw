---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const coreRoutes = [
  {
    tag: '先上手',
    title: '文档教程',
    href: withBase('/docs/'),
    summary: '从安装、接入、规则、命令到日常使用，一步一步把 OpenClaw 养起来。',
    audience: '适合第一次接触、已经装好但不会用、想重新梳理流程的人。',
    bullets: ['先看 7 步教程', '常用命令速查', 'FAQ 排错入口'],
    action: '进入文档教程'
  },
  {
    tag: '看外部入口',
    title: '资源导航',
    href: withBase('/links/'),
    summary: '集中放官网、官方文档、SkillHub、版本发布和精选文章，不用到处翻链接。',
    audience: '适合需要补官网信息、找技能、查版本和收藏外部资料的人。',
    bullets: ['官网与官方文档', 'SkillHub 与 Releases', '精选中文文章'],
    action: '打开资源导航'
  },
  {
    tag: '看能做什么',
    title: '案例',
    href: withBase('/cases/'),
    summary: '用技术小白也能看懂的方式，把 OpenClaw 能落地到哪些真实场景讲清楚。',
    audience: '适合先判断值不值得学、值不值得装、值不值得交付的人。',
    bullets: ['内容运营案例', '办公协同案例', '个人生活助手案例'],
    action: '查看案例'
  },
  {
    tag: '自己装或找我做',
    title: '安装交付服务',
    href: withBase('/service/'),
    summary: '把自己安装、找我交付、已在使用后的排错和支持，全都收进一个入口页。',
    audience: '适合准备上手、已经上手、或需要交付支持的人。',
    bullets: ['自己安装路线', '交付服务说明', '排错与联系入口'],
    action: '进入安装交付服务'
  }
];

const useFlows = [
  ['第一次来', '先去文档教程，再把资源导航收藏起来。'],
  ['想判断值不值得', '先看案例，再看安装交付服务页决定自己装还是找我交付。'],
  ['已经在使用', '把这里当成固定首页，四个入口足够覆盖日常大多数需求。']
];

const reasons = [
  {
    title: '这不是一堆零散页面',
    text: '首页只做导航，不再把交付、案例、说明混在一块。你一进来就知道该往哪走。'
  },
  {
    title: '它是给技术小白准备的',
    text: '默认你不懂太多技术术语，所以优先讲“怎么开始、怎么用、遇到问题怎么办”。'
  },
  {
    title: '也能服务已经在用的人',
    text: '已经交付的用户也可以把这里当日常入口，查文档、看命令、找资源、补场景都方便。'
  }
];
---

<MarketingLayout
  title="虾客AI"
  description="给对 OpenClaw 感兴趣的技术小白准备的导航首页：文档教程、资源导航、案例、安装交付服务四个核心入口。"
>
  <main class="page">
    <div class="container">
      <section class="page-hero">
        <div class="hero-grid">
          <article>
            <span class="eyebrow">导航首页</span>
            <h1>把 OpenClaw 养起来，从这四个入口走就够了。</h1>
            <p class="lead">
              这里不是只给新客户看的介绍页，也不是只给已交付用户看的说明页。
              它应该同时服务三类人：刚感兴趣的人、准备开始的人、已经在日常使用的人。
            </p>
            <div class="action-row">
              <a class="button button-primary" href={withBase('/docs/')}>先去文档教程</a>
              <a class="button button-secondary" href={withBase('/service/')}>看安装交付服务</a>
            </div>
          </article>

          <aside class="hero-aside">
            <span class="section-kicker">怎么用这个站</span>
            <ul class="simple-list">
              {useFlows.map(([title, text]) => (
                <li>
                  <strong>{title}</strong>
                  <br />
                  {text}
                </li>
              ))}
            </ul>
          </aside>
        </div>
      </section>

      <section class="section">
        <div class="section-header">
          <div>
            <span class="section-kicker">四个核心入口</span>
            <h2>以后不再分“营销页”和“交付页”，统一从这里分流。</h2>
          </div>
          <p class="section-copy">
            四块内容分别承担学习、查资料、看场景、决定安装与交付。结构简单，长期也更好维护。
          </p>
        </div>

        <div class="route-grid">
          {coreRoutes.map((item) => (
            <a class="route-card" href={item.href}>
              <span class="card-tag">{item.tag}</span>
              <h3 class="card-title">{item.title}</h3>
              <p class="card-meta">{item.summary}</p>
              <p class="card-meta"><strong>适合谁：</strong>{item.audience}</p>
              <ul class="bullet-list">
                {item.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
              <p class="card-meta"><strong>下一步：</strong>{item.action}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="split-grid">
          <article class="summary-card">
            <span class="section-kicker">为什么这样改</span>
            <h2>首页只做导航，交付相关全部收进一个入口页。</h2>
            <div class="mini-grid">
              {reasons.map((item) => (
                <article class="mini-card">
                  <strong>{item.title}</strong>
                  <span>{item.text}</span>
                </article>
              ))}
            </div>
          </article>

          <article class="note-card">
            <span class="status-chip support">建议收藏</span>
            <h3 class="card-title">如果你已经开始用 OpenClaw，这个站应该是你的固定起点。</h3>
            <p class="card-meta">
              以后需要查命令、回看教程、找外部链接、补看案例、决定要不要找我帮你做交付，
              都不需要再重新找聊天记录或翻仓库页面。
            </p>
            <div class="action-row">
              <a class="button button-primary" href={withBase('/links/')}>打开资源导航</a>
              <a class="button button-secondary" href={withBase('/cases/')}>补看案例</a>
            </div>
          </article>
        </div>
      </section>
    </div>
  </main>
</MarketingLayout>
