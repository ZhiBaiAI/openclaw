---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const primaryActions = [
  { label: '我先看案例', href: withBase('/cases/'), style: 'button-primary' },
  { label: '我开始安装', href: withBase('/docs/'), style: 'button-secondary' },
  { label: '我想直接落地', href: withBase('/service/'), style: 'button-secondary' }
];

const coreRoutes = [
  {
    tag: '先开始动手',
    title: '文档教程',
    href: withBase('/docs/'),
    summary: '从安装、接入、规则、命令到日常使用，按顺序把 OpenClaw 跑起来。',
    bullets: ['7 步总览', '命令速查', 'FAQ 排错'],
    action: '进入文档教程'
  },
  {
    tag: '先判断场景',
    title: '案例',
    href: withBase('/cases/'),
    summary: '先看别人怎么把 OpenClaw 用进内容、办公和个人工作流，再判断适不适合你。',
    bullets: ['内容运营', '办公协同', '个人助手'],
    action: '查看案例'
  },
  {
    tag: '先查资料',
    title: '资源导航',
    href: withBase('/links/'),
    summary: '官网、文档、技能市场、模型平台和常用工具，都集中在这里。',
    bullets: ['官网与文档', '技能市场', '模型平台'],
    action: '打开资源导航'
  },
  {
    tag: '先解决落地',
    title: '安装与支持',
    href: withBase('/service/'),
    summary: '安装遇阻、环境复杂，或者需要协助时，直接从这里进入。',
    bullets: ['安装支持', '排错协助', '联系入口'],
    action: '查看服务'
  }
];
---

<MarketingLayout
  title="虾客AI"
  description="围绕 OpenClaw 的文档教程、案例、资源导航和安装支持四个核心入口。"
>
  <main class="page" id="main-content">
    <div class="container home-page">
      <section class="page-intro home-hero">
        <div class="home-hero__content">
          <h1>把 OpenClaw🦞 养起来、用顺手、真正派上用场。</h1>
          <p class="lead">
            看场景、学安装、查资料、找支持，直接进对应页面，不绕路。
          </p>
          <div class="action-row home-hero__actions">
            {primaryActions.map((item) => (
              <a class:list={['button', item.style]} href={item.href}>{item.label}</a>
            ))}
          </div>
        </div>
      </section>

      <section class="section home-sections">
        <div class="home-sections__heading">
          <h2>直接进入</h2>
        </div>

        <div class="home-entry-grid">
          {coreRoutes.map((item) => (
            <a class="home-entry-card" href={item.href}>
              <span class="card-tag">{item.tag}</span>
              <h3>{item.title}</h3>
              <p class="home-entry-card__summary">{item.summary}</p>
              <ul class="directory-inline-list">
                {item.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
              <span class="home-entry-card__action">{item.action}</span>
            </a>
          ))}
        </div>
      </section>
    </div>
  </main>

  <style>
    .home-page {
      display: grid;
      gap: 0.5rem;
    }

    .home-hero {
      padding: 24px;
    }

    .home-hero__content {
      display: grid;
      gap: 16px;
      max-width: 72rem;
      margin: 0 auto;
      justify-items: center;
      text-align: center;
    }

    .home-hero__content h1 {
      max-width: 24ch;
      font-size: clamp(1.9rem, 3vw, 2.8rem);
      line-height: 1.18;
      letter-spacing: -0.01em;
    }

    .home-hero__content .lead {
      max-width: 40rem;
    }

    .home-hero__actions {
      gap: 10px;
      justify-content: center;
    }

    .home-sections {
      display: grid;
      gap: 14px;
      padding-top: 14px;
    }

    .home-sections__heading {
      display: grid;
      gap: 8px;
      align-content: start;
    }

    .home-entry-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .home-entry-card {
      display: grid;
      align-content: start;
      gap: 12px;
      min-height: 100%;
      padding: 18px;
      border-radius: 22px;
      border: 1px solid rgba(91, 68, 52, 0.12);
      background:
        linear-gradient(180deg, rgba(255, 253, 249, 0.99), rgba(248, 242, 234, 0.96)),
        radial-gradient(circle at top right, rgba(186, 99, 54, 0.08), transparent 30%);
      box-shadow:
        0 12px 28px rgba(73, 52, 38, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.7);
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        box-shadow 180ms ease;
    }

    .home-entry-card:hover,
    .home-entry-card:focus-visible {
      transform: translateY(-2px);
      border-color: rgba(186, 99, 54, 0.2);
      box-shadow: 0 14px 28px rgba(73, 52, 38, 0.08);
    }

    .home-entry-card h3,
    .home-entry-card__summary {
      margin: 0;
    }

    .home-entry-card h3 {
      font-size: 1.22rem;
      line-height: 1.16;
    }

    .home-entry-card__summary {
      color: var(--muted);
      font-size: 0.94rem;
      line-height: 1.68;
    }

    .home-entry-card__action {
      margin-top: auto;
      color: var(--accent-deep);
      font-weight: 700;
    }

    @media (max-width: 960px) {
      .home-entry-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .home-hero,
      .home-entry-card {
        padding: 16px;
      }

      .home-hero__content {
        justify-items: start;
        text-align: left;
      }

      .home-hero__content h1,
      .home-hero__content .lead {
        max-width: none;
      }

      .home-hero__actions {
        justify-content: flex-start;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .home-entry-card {
        transition: none;
      }
    }
  </style>
</MarketingLayout>
