---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const quickLinks = [
  {
    title: '未交付客户',
    text: '先看能力、案例和交付方式。',
    href: withBase('/features/'),
    action: '先看方案能力'
  },
  {
    title: '已交付客户',
    text: '直接看文档、命令和支持入口。',
    href: withBase('/docs/'),
    action: '进入使用文档'
  }
];

const capabilityCards = [
  ['部署交付', '电脑、旧设备、云服务器都能部署。'],
  ['工具接入', '聊天入口、邮箱、日历、搜索、浏览器可逐步接入。'],
  ['规则调校', '把提醒节奏、说话方式和边界调清楚。'],
  ['案例教学', '现场演示 1 到 2 个真实用法。'],
  ['后续支持', '文档、命令、FAQ 和支持入口集中保留。'],
  ['资源导航', '官网、SkillHub、精选文章统一整理。']
];

const deliverySteps = [
  ['交付前沟通', '先确认设备、聊天入口和优先场景。'],
  ['环境部署', '完成环境、模型和聊天入口配置。'],
  ['现场演示', '用小案例带你上手。'],
  ['文档支持', '交付后继续靠文档和支持页维护。']
];
---

<MarketingLayout
  title="OpenClaw 交付与使用中心"
  description="给未交付客户看方案和案例，给已交付客户看文档、案例、资源和支持。"
>
  <main class="container">
    <section class="hero landing-hero">
      <div class="hero-grid">
        <article class="hero-copy">
          <span class="eyebrow">交付与使用中心</span>
          <h1>客户入口</h1>
          <p class="lead">未交付客户看方案，已交付客户直接看文档和支持。</p>
          <div class="hero-actions">
            <a class="cta cta-primary" href={withBase('/docs/')}>进入使用文档</a>
            <a class="cta cta-secondary" href={withBase('/service/')}>查看交付服务</a>
            <a class="cta cta-secondary" href={withBase('/cases/')}>看真实案例</a>
          </div>
        </article>

        <aside class="panel">
          <h2>推荐查看路径</h2>
          <div class="path-grid">
            {quickLinks.map((item) => (
              <a class="path-card" href={item.href}>
                <strong>{item.title}</strong>
                <span>{item.text}</span>
                <em>{item.action}</em>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <span class="eyebrow">你在这里能找到什么</span>
          <h2>把交付前、交付中、交付后的入口都收在一起</h2>
        </div>
        <p>按客户视角分入口，减少来回找页面。</p>
      </div>
      <div class="capability-grid">
        {capabilityCards.map(([title, text]) => (
          <article class="capability-card">
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <span class="eyebrow">典型交付</span>
          <h2>从需求沟通到实际使用，通常会经过这四步</h2>
        </div>
        <p>目标很简单：交付后就能直接开始用。</p>
      </div>
      <div class="process-grid">
        {deliverySteps.map(([title, text], index) => (
          <article class="process-card">
            <span class="process-index">0{index + 1}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="spotlight">
        <article class="section-card">
          <span class="eyebrow">如果你还没交付</span>
          <h2>先判断适不适合你的场景，再决定怎么部署。</h2>
          <ul>
            <li>先看<a href={withBase('/features/')}>方案能力</a>，对照你自己的使用场景</li>
            <li>再看<a href={withBase('/cases/')}>真实案例</a>，感受它能怎么落地</li>
            <li>最后看<a href={withBase('/service/')}>交付服务</a>，确认支持设备和交付方式</li>
          </ul>
        </article>

        <article class="section-card">
          <span class="eyebrow">如果你已经交付</span>
          <h2>直接进入文档和支持，不用再到处翻入口。</h2>
          <ul>
            <li>从<a href={withBase('/docs/')}>7 步教程</a>开始补齐安装和使用流程</li>
            <li>遇到问题先看<a href={withBase('/docs/reference/common-commands/')}>命令速查</a>和 FAQ</li>
            <li>需要资源、技能和文章入口时再进<a href={withBase('/links/')}>资源导航</a></li>
          </ul>
        </article>
      </div>
    </section>

    <footer class="footer">
      一个首页，解决客户看方案和交付后使用两件事。
    </footer>
  </main>

  <style>
    .path-grid,
    .capability-grid,
    .process-grid {
      display: grid;
      gap: 16px;
    }

    .landing-hero .hero-grid {
      grid-template-columns: minmax(0, 1.5fr) 320px;
      align-items: start;
      gap: 28px;
    }

    .landing-hero .hero-copy {
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      backdrop-filter: none;
      overflow: visible;
    }

    .landing-hero .hero-copy::before {
      display: none;
    }

    .landing-hero h1 {
      max-width: none;
      margin-top: 16px;
      font-size: clamp(2rem, 4.8vw, 3.6rem);
      line-height: 1.02;
      letter-spacing: -0.03em;
    }

    .landing-hero .lead {
      max-width: 34rem;
      margin-top: 14px;
      font-size: 0.98rem;
      line-height: 1.7;
    }

    .landing-hero .hero-actions {
      margin-top: 18px;
    }

    .landing-hero .panel {
      padding: 16px;
      border-radius: 20px;
      background: rgba(255, 250, 245, 0.68);
      box-shadow: 0 12px 24px rgba(127, 79, 47, 0.06);
    }

    .landing-hero .panel h2 {
      font-size: 1.1rem;
    }

    .path-grid {
      margin-top: 10px;
    }

    .path-card,
    .capability-card,
    .process-card {
      display: grid;
      gap: 10px;
      padding: 18px;
      border-radius: 22px;
      border: 1px solid rgba(217, 94, 57, 0.12);
      background: rgba(255, 248, 241, 0.88);
    }

    .path-card strong,
    .capability-card h3,
    .process-card h3 {
      color: var(--accent-deep);
    }

    .path-card span,
    .path-card em,
    .capability-card p,
    .process-card p {
      color: var(--muted);
      line-height: 1.75;
      margin: 0;
    }

    .path-card em {
      font-style: normal;
      font-weight: 800;
      color: var(--accent);
    }

    .path-card {
      gap: 6px;
      padding: 16px;
      border-radius: 18px;
      background: rgba(255, 252, 247, 0.92);
      box-shadow: none;
    }

    .capability-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .capability-card {
      padding: 22px;
      border-radius: 24px;
      box-shadow: var(--shadow);
      background:
        radial-gradient(circle at top right, rgba(239, 143, 71, 0.1), transparent 32%),
        linear-gradient(180deg, rgba(255, 252, 247, 0.96), rgba(255, 247, 239, 0.9));
    }

    .process-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .process-card {
      padding: 22px;
      border-radius: 24px;
      box-shadow: var(--shadow);
      background:
        linear-gradient(180deg, rgba(255, 252, 247, 0.96), rgba(255, 248, 241, 0.88));
    }

    .process-index {
      width: fit-content;
      padding: 8px 11px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-deep);
      font-weight: 800;
      letter-spacing: 0.04em;
    }

    .section-card ul {
      margin-top: 16px;
    }

    .section-card li {
      margin-bottom: 10px;
    }

    .section-card li a {
      margin: 0 0.18rem;
      color: var(--accent-deep);
      font-weight: 800;
    }

    @media (max-width: 960px) {
      .landing-hero .hero-grid,
      .capability-grid,
      .process-grid {
        grid-template-columns: 1fr;
      }

      .landing-hero h1 {
        max-width: none;
      }
    }
  </style>
</MarketingLayout>
