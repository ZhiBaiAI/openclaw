---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const primaryActions = [
  { label: '我先看案例', href: withBase('/cases/'), style: 'button-primary' },
  { label: '我开始安装', href: withBase('/docs/'), style: 'button-secondary' },
  { label: '我想直接落地', href: withBase('/service/'), style: 'button-secondary' }
];

const coreRoutes = [
  {
    tag: '先开始动手',
    title: '文档教程',
    href: withBase('/docs/'),
    summary: '从安装、接入、规则、命令到日常使用，按顺序把 OpenClaw 跑起来。',
    bullets: ['7 步总览', '命令速查', 'FAQ 排错'],
    action: '进入文档教程'
  },
  {
    tag: '先判断场景',
    title: '案例',
    href: withBase('/cases/'),
    summary: '先看真实场景，再判断 OpenClaw 是否值得你继续投入时间和精力。',
    bullets: ['内容运营', '办公协同', '个人助手'],
    action: '查看案例'
  },
  {
    tag: '先查资料',
    title: '资源导航',
    href: withBase('/links/'),
    summary: '把官网、官方文档、SkillHub、版本发布和精选文章集中在一页。',
    bullets: ['官网与文档', 'SkillHub', 'Releases'],
    action: '打开资源导航'
  },
  {
    tag: '先解决落地',
    title: '安装交付服务',
    href: withBase('/service/'),
    summary: '自己安装、预约支持、排错协助，都从这里进入。',
    bullets: ['自己安装', '服务说明', '联系入口'],
    action: '查看服务'
  }
];

const supportLinks = [
  {
    title: '已经安装好了',
    text: '继续查资料、看官方更新或找常用外链，优先去资源导航。',
    href: withBase('/links/'),
    action: '去资源导航'
  },
  {
    title: '已经开始用了',
    text: '想补场景、补思路或回头看看还能怎么扩展，就去看案例。',
    href: withBase('/cases/'),
    action: '去看案例'
  }
];
---

<MarketingLayout
  title="虾客AI"
  description="围绕 OpenClaw 的文档教程、资源导航、案例和安装交付服务四个核心入口。"
>
  <main class="page" id="main-content">
    <div class="container home-page">
      <section class="page-intro home-hero">
        <div class="home-hero__content">
          <span class="eyebrow">虾客AI</span>
          <h1>想了解、安装或用好 OpenClaw，就从这里选入口。</h1>
          <p class="lead">
            先判断你现在是想了解场景、准备安装，还是希望更快落地，然后直接进入对应页面。
          </p>
          <div class="action-row home-hero__actions">
            {primaryActions.map((item) => (
              <a class:list={['button', item.style]} href={item.href}>{item.label}</a>
            ))}
          </div>
        </div>
      </section>

      <section class="section home-sections">
        <div class="home-sections__heading">
          <h2>四个核心入口</h2>
        </div>

        <div class="home-entry-grid">
          {coreRoutes.map((item) => (
            <a class="home-entry-card" href={item.href}>
              <span class="card-tag">{item.tag}</span>
              <h3>{item.title}</h3>
              <p class="home-entry-card__summary">{item.summary}</p>
              <ul class="directory-inline-list">
                {item.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
              <span class="home-entry-card__action">{item.action}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="section home-support">
        <article class="summary-card home-support__panel">
          <div class="home-support__heading">
            <span class="section-kicker">已经安装或正在使用</span>
            <h2>后续常用入口</h2>
          </div>

          <div class="home-support__grid">
            {supportLinks.map((item) => (
              <a class="mini-card home-support__card" href={item.href}>
                <strong>{item.title}</strong>
                <span>{item.text}</span>
                <em>{item.action}</em>
              </a>
            ))}
          </div>
        </article>
      </section>
    </div>
  </main>

  <style>
    .home-page {
      display: grid;
      gap: 0.5rem;
    }

    .home-hero {
      padding: 24px;
    }

    .home-hero__content {
      display: grid;
      gap: 16px;
      max-width: 52rem;
    }

    .home-hero__actions {
      gap: 10px;
    }

    .home-sections {
      display: grid;
      gap: 14px;
      padding-top: 14px;
    }

    .home-sections__heading {
      display: grid;
      gap: 8px;
      align-content: start;
    }

    .home-entry-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .home-entry-card {
      display: grid;
      align-content: start;
      gap: 12px;
      min-height: 100%;
      padding: 18px;
      border-radius: 22px;
      border: 1px solid rgba(91, 68, 52, 0.12);
      background:
        linear-gradient(180deg, rgba(255, 253, 249, 0.99), rgba(248, 242, 234, 0.96)),
        radial-gradient(circle at top right, rgba(186, 99, 54, 0.08), transparent 30%);
      box-shadow:
        0 12px 28px rgba(73, 52, 38, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.7);
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        box-shadow 180ms ease;
    }

    .home-entry-card:hover,
    .home-entry-card:focus-visible {
      transform: translateY(-2px);
      border-color: rgba(186, 99, 54, 0.2);
      box-shadow: 0 14px 28px rgba(73, 52, 38, 0.08);
    }

    .home-entry-card h3,
    .home-entry-card__summary {
      margin: 0;
    }

    .home-entry-card h3 {
      font-size: 1.22rem;
      line-height: 1.16;
    }

    .home-entry-card__summary,
    .home-support__card span {
      color: var(--muted);
      font-size: 0.94rem;
      line-height: 1.68;
    }

    .home-entry-card__action,
    .home-support__card em {
      margin-top: auto;
      color: var(--accent-deep);
      font-style: normal;
      font-weight: 700;
    }

    .home-support {
      padding-top: 8px;
    }

    .home-support__panel {
      display: grid;
      gap: 14px;
    }

    .home-support__heading {
      display: grid;
      gap: 8px;
    }

    .home-support__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .home-support__card {
      text-decoration: none;
    }

    .home-support__card strong {
      color: var(--text);
    }

    @media (max-width: 960px) {
      .home-entry-grid,
      .home-support__grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .home-hero,
      .home-entry-card {
        padding: 16px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .home-entry-card {
        transition: none;
      }
    }
  </style>
</MarketingLayout>
