---

<MarketingLayout
  title="OpenClaw 案例库 | 个人场景、专业工作流与行业解决方案 | 虾客AI"
  description="从个人场景、专业工作流和行业解决方案三个层次，整理 OpenClaw 的真实落地案例，方便快速判断值不值得做、该从哪里开始。"
  keywords={caseKeywords}
  structuredData={caseStructuredData}
>
  <main class="page" id="main-content">
    <div class="container cases-page">
      <section class="cases-major-nav" aria-label="案例主分类">
        <a class="cases-major-nav__button" href="#personal-cases">通用个人场景</a>
        <a class="cases-major-nav__button" href="#professional-cases">专业场景案例</a>
        <a class="cases-major-nav__button" href="#industry-solutions">行业解决方案</a>
      </section>

      <section class="section cases-major-section" id="personal-cases" data-tabs-root>
        <div class="section-header cases-section-header">
          <h2>通用个人场景</h2>
          <p class="section-copy">{personalCaseCount} 个案例</p>
        </div>

        <div class="cases-subnav" role="tablist" aria-label="通用个人场景分类">
          {personalGroups.map((group, index) => (
            <button
              class:list={['cases-subnav__button', index === 0 && 'is-active']}
              id={`tab-${group.id}`}
              type="button"
              role="tab"
              aria-controls={`panel-${group.id}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
              data-tab-target={group.id}
            >
              <span class="cases-subnav__label">{group.title}</span>
              <span class="cases-subnav__count">{group.items.length} 个示例</span>
            </button>
          ))}
        </div>

        <div class="cases-panels">
          {personalGroups.map((group, index) => (
            <section
              class:list={['cases-panel', index === 0 && 'is-active']}
              id={`panel-${group.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${group.id}`}
              data-tab-panel={group.id}
              hidden={index !== 0}
            >
              <header class="cases-panel__header">
                <div class="cases-panel__heading">
                  <span class="card-tag">{group.tag}</span>
                  <h3>{group.title}</h3>
                </div>
                <span class="cases-panel__count">{group.items.length} 个案例</span>
              </header>

              <p class="cases-panel__summary">{group.summary}</p>

              <div class="personal-case-grid">
                {group.items.map((item) => (
                  <article class="personal-case-card">
                    <div class="personal-case-card__top">
                      <span class="card-tag">{item.tag}</span>
                      <h4>{item.title}</h4>
                    </div>
                    <p class="personal-case-card__summary">{item.summary}</p>
                    <div class="case-signal-list" aria-label="案例提示标签">
                      {(personalCaseSignals[group.id] ?? []).map((signal) => (
                        <span class="case-signal">{signal}</span>
                      ))}
                    </div>
                    <p class="personal-case-card__fit"><strong>适合谁</strong>{item.fit}</p>
                    <div class="personal-case-card__block">
                      <strong>建议先做</strong>
                      <ul class="bullet-list">
                        {item.starts.map((step) => (
                          <li>{step}</li>
                        ))}
                      </ul>
                    </div>
                    <p class="personal-case-card__gain"><strong>最直接的收益</strong>{item.gain}</p>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>

      <section class="section cases-major-section" id="professional-cases" data-tabs-root>
        <div class="section-header cases-section-header">
          <h2>专业场景案例</h2>
          <p class="section-copy">{professionalCaseCount} 个案例</p>
        </div>

        <div class="cases-subnav" role="tablist" aria-label="专业场景案例分类">
          {professionalCases.map((item, index) => (
            <button
              class:list={['cases-subnav__button', index === 0 && 'is-active']}
              id={`tab-${item.id}`}
              type="button"
              role="tab"
              aria-controls={`panel-${item.id}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
              data-tab-target={item.id}
            >
              <span class="cases-subnav__label">{item.title}</span>
              <span class="cases-subnav__count">1 个示例</span>
            </button>
          ))}
        </div>

        <div class="cases-panels">
          {professionalCases.map((item, index) => (
            <section
              class:list={['cases-panel', index === 0 && 'is-active']}
              id={`panel-${item.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${item.id}`}
              data-tab-panel={item.id}
              hidden={index !== 0}
            >
              <header class="cases-panel__header">
                <div class="cases-panel__heading">
                  <span class="card-tag">{item.tag}</span>
                  <h3>{item.title}</h3>
                </div>
                <span class="professional-card__level">{item.level}</span>
              </header>

              <p class="cases-panel__summary">{item.summary}</p>
              <div class="case-signal-list" aria-label="案例提示标签">
                {(professionalCaseSignals[item.id] ?? []).map((signal) => (
                  <span class="case-signal">{signal}</span>
                ))}
              </div>

              <div class="detail-grid">
                <article class="panel-detail-card">
                  <strong>适合谁</strong>
                  <p>{item.fit}</p>
                </article>
                <article class="panel-detail-card">
                  <strong>建议先做</strong>
                  <ul class="bullet-list">
                    {item.starts.map((step) => (
                      <li>{step}</li>
                    ))}
                  </ul>
                </article>
                <article class="panel-detail-card">
                  <strong>边界提醒</strong>
                  <p>{item.boundary}</p>
                </article>
              </div>
            </section>
          ))}
        </div>
      </section>

      <section class="section cases-major-section" id="industry-solutions" data-tabs-root>
        <div class="section-header cases-section-header">
          <h2>行业解决方案</h2>
          <p class="section-copy">{industryCaseCount} 个行业</p>
        </div>

        <div class="cases-subnav" role="tablist" aria-label="行业解决方案分类">
          {industrySolutions.map((item, index) => (
            <button
              class:list={['cases-subnav__button', index === 0 && 'is-active']}
              id={`tab-${item.id}`}
              type="button"
              role="tab"
              aria-controls={`panel-${item.id}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
              data-tab-target={item.id}
            >
              <span class="cases-subnav__label">{item.title}</span>
              <span class="cases-subnav__count">1 个示例</span>
            </button>
          ))}
        </div>

        <div class="cases-panels">
          {industrySolutions.map((item, index) => (
            <section
              class:list={['cases-panel', index === 0 && 'is-active']}
              id={`panel-${item.id}`}
              role="tabpanel"
              aria-labelledby={`tab-${item.id}`}
              data-tab-panel={item.id}
              hidden={index !== 0}
            >
              <header class="cases-panel__header">
                <div class="cases-panel__heading">
                  <span class="card-tag">{item.tag}</span>
                  <h3>{item.title}</h3>
                </div>
                <span class:list={['risk-chip', item.risk === '低风险' && 'is-low', item.risk === '中风险' && 'is-mid', item.risk === '高风险' && 'is-high']}>{item.risk}</span>
              </header>

              <p class="cases-panel__summary">{item.cut}</p>
              <div class="case-signal-list" aria-label="案例提示标签">
                {(industrySolutionSignals[item.id] ?? []).map((signal) => (
                  <span class="case-signal">{signal}</span>
                ))}
              </div>

              <div class="detail-grid">
                <article class="panel-detail-card">
                  <strong>核心痛点</strong>
