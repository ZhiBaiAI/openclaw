---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;

const cases = [
  {
    tag: '内容运营',
    title: '把选题、资料收集和草稿整理交给 OpenClaw 打底',
    summary: '适合个人创作者和小团队，用它先做信息收集、选题整理和初稿准备。',
    fit: '如果你经常卡在“今天写什么、资料从哪找、标题怎么起”，这类案例最容易看出价值。',
    result: '重点不是全自动发内容，而是把最耗时间的准备环节先交给 OpenClaw 做。'
  },
  {
    tag: '办公协同',
    title: '把 OpenClaw 放进飞书、微信、钉钉这些高频沟通入口',
    summary: '适合日常办公、团队协同和高频问答，让助手直接出现在你本来就会打开的地方。',
    fit: '如果你不想多开一个系统，而是想在原来的工作入口里直接用 AI，这类场景更适合你。',
    result: '真正的价值是减少切换成本，而不是把所有工作都自动化。'
  },
  {
    tag: '个人助手',
    title: '把 OpenClaw 调成你的日常生活与工作助手',
    summary: '适合提醒、整理、记录和轻量建议这类高频重复问题。',
    fit: '如果你是技术小白，通常从个人助手类场景开始最容易建立使用习惯。',
    result: '先从“每天都会问的事”开始，最容易把 OpenClaw 真正养熟。'
  },
  {
    tag: '信息筛选',
    title: '用固定规则筛公开信息，生成每日观察和候选列表',
    summary: '适合把重复搜集、比对、整理的动作，变成固定流程。',
    fit: '如果你每天都要看同一类信息，再手工汇总，这类场景会明显节省时间。',
    result: '它更像自动整理线索的助手，不是替你做最终决策。'
  }
];

const tips = [
  '先挑最接近自己日常的案例，不用一口气全看。',
  '看案例的重点，不是功能名，而是“它帮你省掉了哪一段重复动作”。',
  '如果案例看完觉得自己还是不会配，就直接去安装交付服务页。'
];
---

<MarketingLayout
  title="OpenClaw 案例"
  description="用技术小白也能看懂的方式，整理 OpenClaw 的真实使用场景，帮助判断它适不适合自己。"
>
  <main class="page">
    <div class="container">
      <section class="page-hero">
        <div class="hero-grid">
          <article>
            <span class="eyebrow">案例</span>
            <h1>先别急着研究功能，先看它能不能帮你做成事。</h1>
            <p class="lead">
              这一页不讲复杂原理，只讲最实际的问题：
              OpenClaw 适合落在哪些场景，哪些人最容易先用起来，最后能帮你省掉什么。
            </p>
            <div class="action-row">
              <a class="button button-primary" href="#case-list">直接看案例</a>
              <a class="button button-secondary" href={withBase('/service/')}>不会配就看安装交付服务</a>
            </div>
          </article>

          <aside class="hero-aside">
            <span class="section-kicker">怎么看这页</span>
            <ul class="simple-list">
              {tips.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </aside>
        </div>
      </section>

      <section class="section" id="case-list">
        <div class="section-header">
          <div>
            <span class="section-kicker">场景清单</span>
            <h2>先从最像你日常生活或工作的那一类开始看。</h2>
          </div>
          <p class="section-copy">
            你不需要先理解所有技术词。只要先判断“这个场景是不是我真的会每天用到”，就够了。
          </p>
        </div>

        <div class="card-grid case-grid">
          {cases.map((item) => (
            <article class="info-card">
              <span class="card-tag">{item.tag}</span>
              <h3 class="card-title">{item.title}</h3>
              <p class="card-meta">{item.summary}</p>
              <ul class="bullet-list">
                <li>{item.fit}</li>
                <li>{item.result}</li>
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <div class="split-grid">
          <article class="summary-card">
            <span class="section-kicker">给新客户的建议</span>
            <h2>如果你只是想先判断值不值得做，案例页比参数页更重要。</h2>
            <p class="card-copy">
              因为真正影响你是否会长期使用的，不是模型名字，也不是一长串配置项，
              而是它能不能进入你原本的工作和生活流程。
            </p>
          </article>

          <article class="note-card">
            <span class="status-chip support">下一步</span>
            <h3 class="card-title">看完案例以后，通常只需要做一个决定。</h3>
            <p class="card-meta">
              如果你已经知道“这就是我想要的方向”，那就去文档教程自己装，
              或直接去安装交付服务页找我帮你落地。
            </p>
            <div class="action-row">
              <a class="button button-primary" href={withBase('/docs/')}>自己开始装</a>
              <a class="button button-secondary" href={withBase('/service/')}>找我做交付</a>
            </div>
          </article>
        </div>
      </section>
    </div>
  </main>

  <style>
    .case-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    @media (max-width: 960px) {
      .case-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MarketingLayout>
