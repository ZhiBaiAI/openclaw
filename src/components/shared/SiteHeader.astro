---
import { SITE_NAME, SITE_NAV_ITEMS, SITE_SLOGAN } from '../../data/site.mjs';

export interface Props {
  navLabel?: string;
}

const { navLabel = '站点导航' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;
const normalize = (path: string) => (path === '/' ? '/' : `${path.replace(/\/+$/, '')}/`);
const rawPath = (() => {
  const pathname = Astro.url.pathname || '/';
  return base && pathname.startsWith(base) ? pathname.slice(base.length) || '/' : pathname;
})();
const currentPath = normalize(rawPath);

const hasSearch = Astro.slots.has('search');
const hasUtilities = Astro.slots.has('utilities');
---

<div class="shared-header">
  <div class="shared-header__surface">
    <div class="shared-header__main">
      <div class="shared-header__identity">
        <a class="shared-header__brand" href={withBase('/')}>
          <span class="shared-header__mark">
            <span class="shared-header__orb" aria-hidden="true"></span>
            <span class="shared-header__brand-copy">
              <span class="shared-header__title">{SITE_NAME}</span>
              <span class="shared-header__subtitle">{SITE_SLOGAN}</span>
            </span>
          </span>
        </a>

        <nav class="shared-header__nav" aria-label={navLabel}>
          {
            SITE_NAV_ITEMS.map((item) => {
              const isActive = currentPath === item.path || currentPath.startsWith(item.path);
              return (
                <a class:list={['shared-header__link', { active: isActive }]} href={withBase(item.path)}>
                  <span>{item.label}</span>
                </a>
              );
            })
          }
        </nav>
      </div>

      {
        (hasSearch || hasUtilities) && (
          <div class="shared-header__tools">
            {hasSearch && (
              <div class="shared-header__search">
                <slot name="search" />
              </div>
            )}
            {hasUtilities && (
              <div class="shared-header__utilities">
                <slot name="utilities" />
              </div>
            )}
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  .shared-header {
    width: 100%;
  }

  .shared-header__surface {
    position: relative;
    display: grid;
    gap: 0.65rem;
    padding: 0.68rem 0.78rem;
    border: 1px solid rgba(91, 68, 52, 0.1);
    border-radius: 1.1rem;
    background:
      linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(250, 245, 239, 0.95)),
      radial-gradient(circle at top right, rgba(186, 99, 54, 0.04), transparent 26%);
    box-shadow:
      0 10px 24px rgba(73, 52, 38, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.75);
    overflow: hidden;
  }

  .shared-header__surface::after {
    content: '';
    position: absolute;
    inset: auto 0.9rem 0.7rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(123, 67, 37, 0), rgba(123, 67, 37, 0.14), rgba(123, 67, 37, 0));
    pointer-events: none;
  }

  .shared-header__main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem 0.9rem;
    min-width: 0;
  }

  .shared-header__identity {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex: 1 1 auto;
    min-width: 0;
  }

  .shared-header__brand {
    display: block;
    min-width: 0;
    color: inherit;
    text-decoration: none;
    flex: none;
  }

  .shared-header__mark {
    display: inline-flex;
    align-items: center;
    gap: 0.62rem;
    width: fit-content;
    max-width: 100%;
    padding: 0.56rem 0.8rem 0.56rem 0.68rem;
    border-radius: 0.95rem;
    border: 1px solid rgba(91, 68, 52, 0.1);
    background: rgba(255, 252, 248, 0.94);
    box-shadow: 0 8px 16px rgba(73, 52, 38, 0.04);
  }

  .shared-header__orb {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #ba6336, #d98b54);
    box-shadow:
      0 0 0 0.26rem rgba(186, 99, 54, 0.08),
      0 4px 10px rgba(186, 99, 54, 0.1);
    flex: none;
  }

  .shared-header__brand-copy {
    display: grid;
    gap: 0.04rem;
    min-width: 0;
  }

  .shared-header__title {
    color: #7b4325;
    font-family: 'Fraunces', 'Noto Serif SC', serif;
    font-size: 0.94rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    line-height: 1.1;
  }

  .shared-header__subtitle {
    color: #6c5a4e;
    font-size: 0.72rem;
    line-height: 1.2;
  }

  .shared-header__tools {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.8rem;
    flex: 0 1 auto;
    min-width: 0;
  }

  .shared-header__search {
    flex: 1 1 20rem;
    min-width: min(20rem, 100%);
    max-width: 32rem;
  }

  .shared-header__search :global(.search) {
    width: 100%;
  }

  .shared-header__search :global(button),
  .shared-header__search :global(label) {
    border-radius: 999px;
    border-color: rgba(91, 68, 52, 0.1);
    background: rgba(255, 252, 248, 0.92);
    box-shadow: none;
  }

  .shared-header__utilities {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .shared-header__utilities :global(.social-icons) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-right: 0.8rem;
    border-inline-end: 1px solid rgba(91, 68, 52, 0.1);
  }

  .shared-header__nav {
    display: flex;
    flex: 1 1 auto;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.35rem;
    min-width: 0;
    overflow-x: auto;
    padding: 0.1rem 0;
    scrollbar-width: none;
  }

  .shared-header__nav::-webkit-scrollbar {
    display: none;
  }

  .shared-header__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: none;
    padding: 0.46rem 0.72rem;
    border-radius: 999px;
    border: 1px solid rgba(91, 68, 52, 0.1);
    background: rgba(255, 252, 248, 0.86);
    color: #6c5a4e;
    font-size: 0.82rem;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .shared-header__link:hover,
  .shared-header__link:focus-visible {
    color: #7b4325;
    border-color: rgba(186, 99, 54, 0.18);
    background: rgba(255, 249, 241, 0.96);
    transform: translateY(-1px);
    box-shadow: 0 6px 12px rgba(73, 52, 38, 0.04);
  }

  .shared-header__link.active {
    color: #7b4325;
    border-color: rgba(186, 99, 54, 0.2);
    background: linear-gradient(180deg, rgba(253, 241, 232, 0.98), rgba(247, 232, 219, 0.92));
    box-shadow:
      inset 0 0 0 1px rgba(186, 99, 54, 0.02),
      0 6px 12px rgba(73, 52, 38, 0.04);
  }

  .shared-header__link.active::after {
    content: '';
    position: absolute;
    inset: auto 0.7rem 0.26rem;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(123, 67, 37, 0.18), rgba(123, 67, 37, 0.82), rgba(123, 67, 37, 0.18));
  }

  @media (max-width: 58rem) {
    .shared-header__main {
      flex-direction: column;
      align-items: flex-start;
    }

    .shared-header__identity {
      width: 100%;
      flex-wrap: wrap;
    }

    .shared-header__tools {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .shared-header__search {
      width: 100%;
      max-width: none;
    }

    .shared-header__nav {
      width: 100%;
    }
  }

  @media (max-width: 40rem) {
    .shared-header__surface {
      padding: 0.66rem;
      border-radius: 0.95rem;
    }

    .shared-header__subtitle {
      white-space: normal;
    }

    .shared-header__utilities {
      flex-wrap: wrap;
      width: 100%;
    }

    .shared-header__utilities :global(.social-icons) {
      padding-right: 0;
      border-inline-end: 0;
    }

    .shared-header__link {
      font-size: 0.8rem;
    }
  }
</style>
