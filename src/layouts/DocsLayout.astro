---
import MarketingLayout from './MarketingLayout.astro';
import { DOCS_SIDEBAR, docHref } from '../data/docs.mjs';

export interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  currentId: string;
  currentSection?: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  prevItem?: { id: string; label: string } | null;
  nextItem?: { id: string; label: string } | null;
  keywords?: string[];
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  seoTitle = `${title} | OpenClaw 文档教程 | 虾客AI`,
  description = 'OpenClaw 文档教程',
  currentId,
  currentSection = '文档教程',
  headings = [],
  prevItem = null,
  nextItem = null,
  keywords = [],
  structuredData = []
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const outlineItems = headings.filter((item) => item.depth === 2 || item.depth === 3);
const sidebarSections = DOCS_SIDEBAR.map((section) => ({
  ...section,
  isCurrent: section.items.some((item) => item.id === currentId)
}));
---

<MarketingLayout
  title={seoTitle}
  description={description}
  keywords={keywords}
  ogType="article"
  structuredData={structuredData}
>
  <main class="page docs-page" id="main-content">
    <div class="container docs-shell">
      <aside class="docs-sidebar">
        <div class="docs-sidebar__panel">
          <div class="docs-sidebar__intro">
            <span class="section-kicker">文档导航</span>
            <h2>从上手到排错，按顺序查就够了。</h2>
            <p class="docs-sidebar__copy">
              先走教程，再看参考资料和常见问题。尽量不要在聊天记录、截图和零散笔记之间反复切换。
            </p>
          </div>

          <nav aria-label="文档目录" class="docs-sidebar__nav">
            {
              sidebarSections.map((section) => (
                <details class="docs-sidebar__section" open={section.isCurrent}>
                  <summary class="docs-sidebar__summary">
                    <span class="docs-sidebar__summary-copy">
                      <span class="docs-sidebar__summary-label">{section.label}</span>
                      <span class="docs-sidebar__summary-meta">{section.items.length} 篇</span>
                    </span>
                    <span class="docs-sidebar__summary-icon" aria-hidden="true"></span>
                  </summary>
                  <div class="docs-sidebar__links">
                    {section.items.map((item) => (
                      <a class:list={['docs-sidebar__link', { active: item.id === currentId }]} href={docHref(item.id, base)}>
                        {item.label}
                      </a>
                    ))}
                  </div>
                </details>
              ))
            }
          </nav>
        </div>
      </aside>

      <section class="docs-main">
        <article class="docs-article content-panel">
          <div class="docs-pagehead">
            <span class="eyebrow">{currentSection}</span>
            <h1>{title}</h1>
            {description && <p class="docs-pagehead__lead">{description}</p>}
          </div>

          <slot />

          <div class="docs-pagination">
            {prevItem && (
              <a class="docs-pagination__card" href={docHref(prevItem.id, base)}>
                <span class="docs-pagination__label">上一篇</span>
                <strong>{prevItem.label}</strong>
              </a>
            )}
            {nextItem && (
              <a class="docs-pagination__card" href={docHref(nextItem.id, base)}>
                <span class="docs-pagination__label">下一篇</span>
                <strong>{nextItem.label}</strong>
              </a>
            )}
          </div>
        </article>

        <aside class="docs-rail">
          <div class="docs-rail__panel">
            <span class="section-kicker">页内索引</span>
            {outlineItems.length > 0 ? (
              <nav class="docs-outline" aria-label="页内目录">
                {outlineItems.map((item) => (
                  <a class:list={['docs-outline__link', `depth-${item.depth}`]} href={`#${item.slug}`}>
                    {item.text}
                  </a>
                ))}
              </nav>
            ) : (
              <p class="docs-rail__copy">这页内容较短，按正文顺着读即可。</p>
            )}
          </div>

          <div class="docs-rail__panel">
            <span class="section-kicker">快捷入口</span>
            <div class="docs-shortcuts">
              <a href={`${base}/service/`}>
                <strong>安装部署支持</strong>
                <span>安装部署、配置支持和排错处理都可以从这里继续。</span>
              </a>
              <a href={`${base}/links/`}>
                <strong>资源导航</strong>
                <span>官网、官方文档、SkillHub 和外部文章集中查看。</span>
              </a>
              <a href={`${base}/cases/`}>
                <strong>案例</strong>
                <span>先看真实场景，再决定学到什么程度、要不要继续投入。</span>
              </a>
            </div>
          </div>
        </aside>
      </section>
    </div>
  </main>
</MarketingLayout>

<style>
  .docs-shell {
    display: grid;
    grid-template-columns: minmax(264px, 296px) minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .docs-sidebar,
  .docs-rail {
    position: sticky;
    top: 7.8rem;
  }

  .docs-sidebar__panel,
  .docs-rail__panel,
  .docs-pagination__card {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(250, 245, 239, 0.94));
    box-shadow: 0 12px 28px rgba(73, 52, 38, 0.06);
  }

  .docs-sidebar__panel,
  .docs-rail__panel {
    padding: 16px;
  }

  .docs-main {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(234px, 272px);
    gap: 16px;
    align-items: start;
  }

  @media (min-width: 1201px) {
    .docs-main {
      padding-top: 10px;
    }
  }

  .docs-sidebar__intro {
    display: grid;
    gap: 8px;
  }

  .docs-sidebar__intro h2 {
    margin-top: 0;
    font-size: clamp(1.25rem, 2vw, 1.6rem);
  }

  .docs-sidebar__copy,
  .docs-rail__copy,
  .docs-pagehead__lead {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
    overflow-wrap: anywhere;
  }

  .docs-sidebar__nav {
    display: grid;
    gap: 12px;
    margin-top: 14px;
  }

  .docs-sidebar__section {
    padding-top: 10px;
    border-top: 1px solid rgba(91, 68, 52, 0.08);
  }

  .docs-sidebar__section:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .docs-sidebar__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    min-height: 44px;
    list-style: none;
    cursor: pointer;
  }

  .docs-sidebar__summary::-webkit-details-marker {
    display: none;
  }

  .docs-sidebar__summary-copy {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .docs-sidebar__summary-label {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text);
  }

  .docs-sidebar__summary-meta {
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  .docs-sidebar__summary-icon {
    width: 10px;
    height: 10px;
    border-right: 2px solid rgba(123, 67, 37, 0.72);
    border-bottom: 2px solid rgba(123, 67, 37, 0.72);
    transform: rotate(45deg);
    transition: transform 180ms ease;
    flex: none;
  }

  .docs-sidebar__section[open] .docs-sidebar__summary-icon {
    transform: rotate(225deg);
  }

  .docs-sidebar__links {
    display: grid;
    gap: 6px;
    margin-top: 10px;
  }

  .docs-sidebar__link,
  .docs-outline__link,
  .docs-shortcuts a {
    display: grid;
    gap: 6px;
    text-decoration: none;
  }

  .docs-sidebar__link {
    min-height: 44px;
    padding: 9px 11px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(91, 68, 52, 0.08);
    background: rgba(255, 252, 248, 0.86);
    color: var(--muted);
    line-height: 1.44;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .docs-sidebar__link:hover,
  .docs-sidebar__link:focus-visible,
  .docs-sidebar__link.active {
    color: var(--accent-deep);
    border-color: rgba(186, 99, 54, 0.18);
    background: linear-gradient(180deg, rgba(253, 241, 232, 0.98), rgba(247, 232, 219, 0.92));
    transform: translateY(-1px);
  }

  .docs-rail {
    align-self: start;
    display: grid;
    gap: 16px;
    align-content: start;
  }

  .docs-article {
    align-self: start;
    min-width: 0;
    padding: 16px;
  }

  .docs-pagehead {
    display: grid;
    gap: 10px;
    margin-top: 0;
    margin-bottom: 18px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(91, 68, 52, 0.1);
  }

  .docs-pagehead h1,
  .docs-pagehead__lead {
    margin: 0;
  }

  .docs-article > :global(:first-child) {
    margin-top: 0;
  }

  .docs-article :global(h1),
  .docs-article :global(h2),
  .docs-article :global(h3) {
    scroll-margin-top: 7.5rem;
  }

  .docs-article :global(h2) {
    margin-top: 1.7rem;
    margin-bottom: 0.7rem;
    font-size: clamp(1.4rem, 2.4vw, 1.85rem);
  }

  .docs-article :global(h3) {
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 1.12rem;
  }

  .docs-article :global(p),
  .docs-article :global(li),
  .docs-article :global(blockquote) {
    color: var(--muted);
    line-height: 1.75;
    font-size: 0.97rem;
    overflow-wrap: anywhere;
  }

  .docs-article :global(p) {
    margin: 0 0 0.9rem;
  }

  .docs-article :global(ul),
  .docs-article :global(ol) {
    margin: 0.75rem 0 1rem;
    padding-left: 1.3rem;
  }

  .docs-article :global(li + li) {
    margin-top: 0.3rem;
  }

  .docs-article :global(code) {
    padding: 0.18rem 0.4rem;
    border-radius: 0.45rem;
    background: rgba(186, 99, 54, 0.1);
    color: var(--accent-deep);
    font-size: 0.92em;
  }

  .docs-article :global(pre) {
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1rem 0;
    padding: 14px;
    border-radius: var(--radius-lg);
    background: #2b201a;
    box-shadow: inset 0 0 0 1px rgba(255, 217, 191, 0.05);
  }

  .docs-article :global(pre code) {
    padding: 0;
    background: transparent;
    color: #fff4ec;
  }

  .docs-article :global(blockquote) {
    margin: 1rem 0;
    padding: 0.85rem 1rem;
    border-left: 4px solid rgba(186, 99, 54, 0.26);
    background: rgba(255, 248, 238, 0.92);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .docs-article :global(table) {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-collapse: collapse;
    margin: 1rem 0;
    border-radius: var(--radius-md);
    background: rgba(255, 252, 248, 0.9);
  }

  .docs-article :global(th),
  .docs-article :global(td) {
    padding: 10px 12px;
    border: 1px solid rgba(186, 99, 54, 0.1);
    text-align: left;
    overflow-wrap: anywhere;
  }

  .docs-outline,
  .docs-shortcuts {
    display: grid;
    gap: 7px;
    margin-top: 10px;
  }

  .docs-outline__link,
  .docs-shortcuts a {
    min-height: 44px;
    padding: 9px 11px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(91, 68, 52, 0.08);
    background: rgba(255, 252, 248, 0.88);
    color: var(--muted);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .docs-outline__link:hover,
  .docs-outline__link:focus-visible,
  .docs-shortcuts a:hover,
  .docs-shortcuts a:focus-visible {
    transform: translateY(-1px);
    color: var(--accent-deep);
    border-color: rgba(186, 99, 54, 0.18);
    background: rgba(255, 249, 241, 0.96);
  }

  .docs-outline__link.depth-3 {
    margin-left: 12px;
  }

  .docs-shortcuts span {
    line-height: 1.68;
  }

  .docs-pagination {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 18px;
  }

  .docs-pagination__card {
    display: grid;
    gap: 5px;
    min-height: 44px;
    padding: 13px;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .docs-pagination__card:hover,
  .docs-pagination__card:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(186, 99, 54, 0.18);
    box-shadow: 0 12px 24px rgba(73, 52, 38, 0.08);
  }

  .docs-pagination__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 1200px) {
    .docs-shell,
    .docs-main {
      grid-template-columns: 1fr;
    }

    .docs-sidebar,
    .docs-rail {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .docs-sidebar__panel,
    .docs-rail__panel,
    .docs-article,
    .docs-pagination__card {
      padding: 15px;
      border-radius: var(--radius-lg);
    }

    .docs-pagination {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .docs-sidebar__summary-icon,
    .docs-sidebar__link,
    .docs-outline__link,
    .docs-shortcuts a,
    .docs-pagination__card {
      transition: none;
    }
  }
</style>
