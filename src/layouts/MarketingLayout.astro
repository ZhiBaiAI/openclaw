---
import SiteHeader from '../components/shared/SiteHeader.astro';
import { SITE_DESCRIPTION } from '../data/site.mjs';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = SITE_DESCRIPTION } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const routePath =
  base && Astro.url.pathname.startsWith(base)
    ? Astro.url.pathname.slice(base.length) || '/'
    : Astro.url.pathname;

const floatingSupport = routePath.startsWith('/docs')
  ? {
      prompt: '没找到需要内容，或教程有误？扫码反馈',
      title: '文档反馈',
      detail: '安装、配置、报错排查，或者文档哪里缺内容、写得不清楚，都可以直接发我。'
    }
  : routePath.startsWith('/cases')
    ? {
        prompt: '想聊落地细节或定制方案？点击扫码沟通',
        title: '案例咨询',
        detail: '告诉我你的行业、角色和目标，我可以帮你细化落地方式、接入细节和定制方向。'
      }
    : routePath.startsWith('/service')
      ? {
          prompt: '部署安装遇到问题？点击扫码沟通',
          title: '部署支持',
          detail: '环境准备、安装部署、配置排错和接入问题，都可以直接沟通。'
        }
      : null;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f6f2eb" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,800&family=Noto+Sans+SC:wght@400;500;700;900&display=swap');

      :root {
        --bg: #f6f2eb;
        --bg-soft: #fbf8f3;
        --panel: rgba(255, 252, 247, 0.9);
        --panel-strong: #fffdf9;
        --line: rgba(91, 68, 52, 0.12);
        --line-strong: rgba(91, 68, 52, 0.2);
        --text: #241914;
        --muted: #69584c;
        --accent: #ba6336;
        --accent-deep: #7b4325;
        --accent-soft: rgba(186, 99, 54, 0.1);
        --support: #3d6352;
        --shadow: 0 16px 40px rgba(73, 52, 38, 0.08);
        --radius-xl: 24px;
        --radius-lg: 18px;
        --radius-md: 14px;
        --max-width: 1180px;
        --floating-tools-right: clamp(1.05rem, 2.4vw, 1.9rem);
        --floating-tool-size: 64px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        color-scheme: light;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family: 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        overflow-x: hidden;
        background:
          radial-gradient(circle at top left, rgba(223, 178, 142, 0.18), transparent 26%),
          linear-gradient(180deg, #fcfaf6 0%, #f5efe7 42%, #f1ebe2 100%);
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(80, 57, 42, 0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(80, 57, 42, 0.015) 1px, transparent 1px);
        background-size: 32px 32px;
        mask-image: radial-gradient(circle at center, black 28%, transparent 82%);
        opacity: 0.35;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a,
      button,
      summary {
        -webkit-tap-highlight-color: rgba(186, 99, 54, 0.12);
        touch-action: manipulation;
      }

      img {
        display: block;
        max-width: 100%;
        height: auto;
      }

      .shell {
        position: relative;
        min-height: 100vh;
      }

      .skip-link {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        z-index: 60;
        padding: 0.7rem 0.95rem;
        border-radius: 999px;
        background: #fffdf9;
        color: var(--accent-deep);
        border: 1px solid rgba(186, 99, 54, 0.18);
        box-shadow: 0 8px 18px rgba(73, 52, 38, 0.08);
        transform: translateY(-160%);
        transition: transform 160ms ease;
      }

      .skip-link:focus-visible {
        transform: translateY(0);
      }

      .back-to-top {
        position: fixed;
        right: var(--floating-tools-right);
        bottom: calc(1.15rem + env(safe-area-inset-bottom));
        z-index: 45;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: var(--floating-tool-size);
        height: var(--floating-tool-size);
        padding: 0;
        border: 1px solid rgba(186, 99, 54, 0.14);
        border-radius: 22px;
        background:
          linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(246, 236, 223, 0.94)),
          radial-gradient(circle at top, rgba(229, 157, 77, 0.18), transparent 55%);
        backdrop-filter: blur(18px);
        color: var(--accent-deep);
        box-shadow:
          0 14px 30px rgba(73, 52, 38, 0.14),
          0 3px 10px rgba(186, 99, 54, 0.08),
          inset 0 1px 0 rgba(255, 255, 255, 0.78);
        opacity: 0;
        pointer-events: none;
        transform: translate3d(0, 14px, 0) scale(0.94);
        transition:
          opacity 220ms ease,
          transform 220ms ease,
          border-color 180ms ease,
          background 180ms ease,
          box-shadow 180ms ease;
      }

      .back-to-top::before {
        content: '';
        position: absolute;
        inset: -7px;
        border-radius: 28px;
        background: radial-gradient(circle, rgba(186, 99, 54, 0.12), transparent 68%);
        opacity: 0;
        transition: opacity 180ms ease;
        pointer-events: none;
      }

      .back-to-top.is-visible {
        opacity: 1;
        pointer-events: auto;
        transform: translate3d(0, 0, 0) scale(1);
      }

      .back-to-top:hover,
      .back-to-top:focus-visible {
        border-color: rgba(186, 99, 54, 0.24);
        background:
          linear-gradient(180deg, rgba(255, 253, 249, 1), rgba(248, 239, 228, 0.98)),
          radial-gradient(circle at top, rgba(229, 157, 77, 0.24), transparent 58%);
        box-shadow:
          0 18px 36px rgba(73, 52, 38, 0.16),
          0 5px 14px rgba(186, 99, 54, 0.12),
          inset 0 1px 0 rgba(255, 255, 255, 0.82);
        transform: translate3d(0, -2px, 0) scale(1.02);
      }

      .back-to-top:hover::before,
      .back-to-top:focus-visible::before {
        opacity: 1;
      }

      .back-to-top__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        background: rgba(186, 99, 54, 0.1);
        line-height: 0;
      }

      .floating-support {
        position: fixed;
        right: var(--floating-tools-right);
        bottom: calc(5.95rem + env(safe-area-inset-bottom));
        z-index: 46;
        display: flex;
        flex-direction: row-reverse;
        align-items: center;
        gap: 0.55rem;
      }

      .floating-support__trigger {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: var(--floating-tool-size);
        height: var(--floating-tool-size);
        border: 1px solid rgba(61, 99, 82, 0.16);
        border-radius: 22px;
        background:
          linear-gradient(180deg, rgba(250, 252, 249, 0.98), rgba(236, 246, 241, 0.94)),
          radial-gradient(circle at top, rgba(61, 99, 82, 0.14), transparent 58%);
        color: var(--support);
        box-shadow:
          0 16px 34px rgba(40, 68, 57, 0.14),
          inset 0 1px 0 rgba(255, 255, 255, 0.78);
        backdrop-filter: blur(18px);
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          box-shadow 180ms ease,
          background 180ms ease;
      }

      .floating-support__trigger:hover,
      .floating-support__trigger:focus-visible {
        border-color: rgba(61, 99, 82, 0.26);
        background:
          linear-gradient(180deg, rgba(253, 255, 252, 1), rgba(239, 248, 243, 0.98)),
          radial-gradient(circle at top, rgba(61, 99, 82, 0.2), transparent 62%);
        box-shadow:
          0 18px 38px rgba(40, 68, 57, 0.16),
          inset 0 1px 0 rgba(255, 255, 255, 0.84);
        transform: translateY(-2px);
      }

      .floating-support__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        background: rgba(61, 99, 82, 0.12);
        line-height: 0;
      }

      .floating-support__hint {
        max-width: 168px;
        padding: 0.68rem 0.82rem;
        border: 1px solid rgba(61, 99, 82, 0.1);
        border-radius: 18px;
        background: rgba(255, 253, 249, 0.95);
        color: var(--text);
        box-shadow:
          0 14px 28px rgba(73, 52, 38, 0.08),
          inset 0 1px 0 rgba(255, 255, 255, 0.82);
        font-size: 0.78rem;
        font-weight: 600;
        line-height: 1.58;
        letter-spacing: normal;
        word-spacing: normal;
      }

      .floating-support__panel {
        position: absolute;
        right: 0;
        bottom: calc(100% + 0.85rem);
        width: min(260px, calc(100vw - 32px));
        padding: 0.9rem;
        border: 1px solid rgba(61, 99, 82, 0.14);
        border-radius: 24px;
        background:
          linear-gradient(180deg, rgba(255, 253, 249, 0.99), rgba(244, 249, 246, 0.96)),
          radial-gradient(circle at top, rgba(61, 99, 82, 0.08), transparent 60%);
        box-shadow:
          0 22px 50px rgba(40, 68, 57, 0.16),
          0 8px 24px rgba(73, 52, 38, 0.08);
      }

      .floating-support__panel[hidden] {
        display: none !important;
      }

      .floating-support__panel::after {
        content: '';
        position: absolute;
        right: 22px;
        bottom: -8px;
        width: 16px;
        height: 16px;
        background: rgba(248, 251, 249, 0.98);
        border-right: 1px solid rgba(61, 99, 82, 0.14);
        border-bottom: 1px solid rgba(61, 99, 82, 0.14);
        transform: rotate(45deg);
      }

      .floating-support__panel-inner {
        display: grid;
        gap: 0.8rem;
      }

      .floating-support__panel-copy {
        display: grid;
        gap: 0.35rem;
      }

      .floating-support__panel-copy strong {
        color: var(--support);
        font-size: 0.94rem;
      }

      .floating-support__panel-copy p {
        margin: 0;
        color: var(--muted);
        font-size: 0.82rem;
        line-height: 1.62;
      }

      .floating-support__qr {
        width: 100%;
        padding: 0.55rem;
        border-radius: 18px;
        border: 1px solid rgba(61, 99, 82, 0.1);
        background: rgba(255, 255, 255, 0.92);
      }

      .container {
        width: min(calc(100% - 32px), var(--max-width));
        margin: 0 auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        padding-top: 0.5rem;
        backdrop-filter: blur(12px);
        background: linear-gradient(180deg, rgba(248, 244, 237, 0.92), rgba(248, 244, 237, 0.68) 72%, rgba(248, 244, 237, 0));
      }

      .site-header::after {
        content: '';
        position: absolute;
        inset: 0 0 auto;
        height: 1px;
        background: linear-gradient(90deg, rgba(123, 67, 37, 0), rgba(123, 67, 37, 0.18), rgba(123, 67, 37, 0));
      }

      .site-header::before {
        content: '';
        position: absolute;
        inset: auto 0 0;
        height: 2.6rem;
        background: linear-gradient(180deg, rgba(248, 244, 237, 0), rgba(248, 244, 237, 0.9));
        pointer-events: none;
      }

      .header-inner {
        position: relative;
        z-index: 1;
        padding: 0 0 0.6rem;
      }

      main.page {
        padding: 16px 0 32px;
      }

      .page-intro {
        position: relative;
        padding: 20px;
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        background:
          linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(250, 245, 238, 0.94)),
          radial-gradient(circle at top right, rgba(186, 99, 54, 0.06), transparent 30%);
        box-shadow:
          0 14px 34px rgba(73, 52, 38, 0.07),
          inset 0 1px 0 rgba(255, 255, 255, 0.72);
      }

      .page-intro::before {
        content: '';
        position: absolute;
        inset: 0 0 auto;
        height: 3px;
        border-radius: inherit;
        background: linear-gradient(90deg, rgba(186, 99, 54, 0.72), rgba(186, 99, 54, 0.18), rgba(186, 99, 54, 0));
      }

      .page-intro__grid {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.85fr);
        gap: 16px;
        align-items: start;
      }

      .page-intro__content,
      .page-intro__aside {
        display: grid;
        align-content: start;
      }

      .page-intro__content {
        gap: 14px;
      }

      .page-intro__content > h1,
      .page-intro__content > .lead,
      .page-intro__content > .action-row,
      .page-intro__content > .intro-facts {
        margin-top: 0;
      }

      .intro-facts {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
      }

      .intro-fact {
        display: grid;
        gap: 4px;
        padding: 10px 11px;
        border-radius: var(--radius-md);
        border: 1px solid rgba(186, 99, 54, 0.1);
        background: rgba(255, 252, 247, 0.86);
      }

      .intro-fact strong {
        color: var(--accent-deep);
        font-size: 0.86rem;
        line-height: 1.35;
      }

      .intro-fact span {
        color: var(--muted);
        font-size: 0.84rem;
        line-height: 1.5;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255, 251, 244, 0.92);
        border: 1px solid rgba(186, 99, 54, 0.14);
        color: var(--accent-deep);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.06em;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        font-family: 'Fraunces', 'Noto Serif SC', serif;
        line-height: 1.08;
        letter-spacing: -0.02em;
        text-wrap: balance;
      }

      h1 {
        font-size: clamp(2rem, 4.2vw, 3.2rem);
      }

      h2 {
        font-size: clamp(1.45rem, 2.5vw, 2rem);
      }

      h3 {
        font-size: 1.16rem;
      }

      .lead,
      .section-intro,
      .card-copy,
      .meta-text,
      p,
      li {
        color: var(--muted);
        line-height: 1.72;
        overflow-wrap: anywhere;
      }

      .lead {
        margin: 0;
        max-width: 48rem;
        font-size: 0.98rem;
      }

      .action-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 0;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 44px;
        padding: 10px 15px;
        border-radius: 999px;
        border: 1px solid rgba(75, 54, 38, 0.12);
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          box-shadow 180ms ease,
          background-color 180ms ease;
      }

      .button:hover,
      .button:focus-visible {
        transform: translateY(-1px);
        border-color: rgba(75, 54, 38, 0.2);
        box-shadow: 0 14px 26px rgba(83, 58, 42, 0.1);
      }

      .button:focus-visible {
        outline: 2px solid rgba(186, 99, 54, 0.28);
        outline-offset: 2px;
      }

      .button-primary {
        color: #fffaf3;
        background: linear-gradient(135deg, var(--accent), #e59d4d);
        border-color: transparent;
      }

      .button-secondary {
        background: rgba(255, 252, 248, 0.9);
      }

      .content-panel,
      .page-intro__aside,
      .island,
      .info-card,
      .note-card,
      .summary-card {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: var(--panel);
        box-shadow: 0 12px 30px rgba(83, 58, 42, 0.07);
      }

      .page-intro__aside,
      .island,
      .summary-card,
      .content-panel {
        padding: 16px;
      }

      .page-intro__aside {
        gap: 12px;
        background:
          linear-gradient(180deg, rgba(255, 252, 248, 0.96), rgba(249, 243, 235, 0.92)),
          radial-gradient(circle at top right, rgba(186, 99, 54, 0.05), transparent 28%);
      }

      .section {
        padding-top: 16px;
      }

      .section[id] {
        scroll-margin-top: 7.5rem;
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 12px;
        padding-top: 12px;
        margin-bottom: 12px;
        border-top: 1px solid rgba(91, 68, 52, 0.1);
      }

      .section-copy {
        max-width: 52ch;
        font-size: 0.94rem;
      }

      .section-kicker {
        display: inline-block;
        margin-bottom: 10px;
        color: var(--accent-deep);
        font-size: 0.84rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .route-grid,
      .card-grid,
      .split-grid,
      .mini-grid,
      .directory-list {
        display: grid;
        gap: 12px;
      }

      .route-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .card-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .split-grid {
        grid-template-columns: 1.08fr 0.92fr;
      }

      .route-card,
      .info-card,
      .note-card {
        position: relative;
        display: grid;
        align-content: start;
        overflow: hidden;
        padding: 16px;
        border-radius: 22px;
        border: 1px solid var(--line);
        background:
          linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(249, 242, 231, 0.9));
        box-shadow: 0 12px 30px rgba(83, 58, 42, 0.07);
        transition:
          transform 220ms ease,
          border-color 220ms ease,
          box-shadow 220ms ease;
      }

      .route-card:hover,
      .info-card:hover,
      .note-card:hover {
        transform: translateY(-2px);
        border-color: var(--line-strong);
        box-shadow: 0 16px 34px rgba(83, 58, 42, 0.11);
      }

      .route-card::before,
      .info-card::before,
      .note-card::before {
        content: '';
        position: absolute;
        inset: auto auto 0 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, rgba(193, 94, 42, 0.16), rgba(193, 94, 42, 0.54), rgba(193, 94, 42, 0));
      }

      .card-tag,
      .status-chip {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 5px 9px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent-deep);
        font-size: 0.76rem;
        font-weight: 700;
      }

      .status-chip.support {
        background: rgba(54, 88, 71, 0.1);
        color: var(--support);
      }

      .card-title {
        margin-top: 8px;
      }

      .card-meta {
        margin-top: 8px;
      }

      .bullet-list,
      .link-list,
      .simple-list {
        display: grid;
        gap: 7px;
        margin: 10px 0 0;
        padding: 0;
        list-style: none;
      }

      .bullet-list li,
      .simple-list li,
      .link-list a,
      .mini-card {
        padding: 10px 12px;
        border-radius: var(--radius-md);
        border: 1px solid rgba(193, 94, 42, 0.1);
        background: rgba(255, 250, 244, 0.8);
      }

      .link-list a,
      .mini-card {
        display: grid;
        gap: 4px;
        min-height: 44px;
        transition:
          transform 180ms ease,
          border-color 180ms ease;
      }

      .link-list a:hover,
      .mini-card:hover {
        transform: translateY(-1px);
        border-color: rgba(193, 94, 42, 0.2);
      }

      .mini-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .directory-row {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(240px, 0.95fr) auto;
        gap: 12px;
        align-items: start;
        padding: 13px 14px;
        border-radius: var(--radius-lg);
        border: 1px solid rgba(91, 68, 52, 0.1);
        background:
          linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(250, 245, 239, 0.94));
        box-shadow: 0 8px 22px rgba(73, 52, 38, 0.05);
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          box-shadow 180ms ease;
      }

      .directory-row:hover,
      .directory-row:focus-within {
        transform: translateY(-1px);
        border-color: rgba(186, 99, 54, 0.18);
        box-shadow: 0 12px 26px rgba(73, 52, 38, 0.08);
      }

      .directory-row__main,
      .directory-row__meta,
      .directory-row__action {
        display: grid;
        align-content: start;
      }

      .directory-row__main {
        gap: 8px;
        min-width: 0;
      }

      .directory-row__meta {
        gap: 8px;
        min-width: 0;
      }

      .directory-row__action {
        justify-items: end;
      }

      .directory-row__title {
        margin: 0;
        color: var(--text);
        font-family: 'Fraunces', 'Noto Serif SC', serif;
        font-size: 1.08rem;
        line-height: 1.18;
      }

      .directory-row__summary,
      .directory-row__meta-copy {
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.62;
        overflow-wrap: anywhere;
      }

      .directory-inline-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .directory-inline-list li {
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(186, 99, 54, 0.1);
        background: rgba(255, 251, 246, 0.9);
        color: var(--muted);
        font-size: 0.82rem;
        line-height: 1.3;
      }

      @keyframes riseIn {
        from {
          opacity: 0;
          transform: translateY(18px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .page-intro,
      .route-card,
      .info-card,
      .note-card,
      .summary-card,
      .page-intro__aside {
        animation: riseIn 560ms ease both;
      }

      @media (max-width: 960px) {
        .section-header {
          flex-direction: column;
          align-items: start;
        }

        .intro-facts {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .page-intro__grid,
        .route-grid,
        .card-grid,
        .split-grid,
        .mini-grid,
        .directory-row {
          grid-template-columns: 1fr;
        }

        .directory-row__action {
          justify-items: start;
        }
      }

      @media (max-width: 640px) {
        :root {
          --floating-tools-right: 0.8rem;
          --floating-tool-size: 58px;
        }

        .container {
          width: min(calc(100% - 20px), var(--max-width));
        }

        .site-header {
          padding-top: 0.5rem;
        }

        main.page {
          padding-top: 22px;
        }

        .page-intro,
        .route-card,
        .info-card,
        .note-card,
        .summary-card,
        .page-intro__aside,
        .island {
          padding: 16px;
          border-radius: 22px;
        }

        h1 {
          font-size: clamp(1.8rem, 8vw, 2.6rem);
        }

        .intro-facts {
          grid-template-columns: 1fr;
        }

        .directory-row {
          padding: 12px 13px;
          border-radius: 18px;
        }

        .back-to-top {
          bottom: calc(1rem + env(safe-area-inset-bottom));
          border-radius: 20px;
        }

        .floating-support {
          bottom: calc(5.5rem + env(safe-area-inset-bottom));
          gap: 0.45rem;
        }

        .floating-support__trigger {
          border-radius: 20px;
        }

        .floating-support__hint {
          max-width: min(144px, calc(100vw - 92px));
          padding: 0.6rem 0.72rem;
          font-size: 0.72rem;
        }

        .floating-support__panel {
          width: min(224px, calc(100vw - 24px));
          padding: 0.82rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .page-intro,
        .route-card,
        .info-card,
        .note-card,
        .summary-card,
        .page-intro__aside {
          animation: none;
        }

        .button,
        .link-list a,
        .mini-card,
        .directory-row,
        .back-to-top {
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到正文</a>
    <div class="shell">
      <header class="site-header">
        <div class="container header-inner">
          <SiteHeader navLabel="主导航" />
        </div>
      </header>

      <slot />

      {floatingSupport && (
        <div class="floating-support" id="floating-support">
          <button
            class="floating-support__trigger"
            id="floating-support-trigger"
            type="button"
            aria-label={`${floatingSupport.title}二维码`}
            aria-controls="floating-support-panel"
            aria-expanded="false"
          >
            <span class="floating-support__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 9.5h10" />
                <path d="M7 13h6.5" />
                <path d="M6.5 18.5 7.2 15H7a5 5 0 0 1-5-5V8a5 5 0 0 1 5-5h10a5 5 0 0 1 5 5v2a5 5 0 0 1-5 5h-5.2L6.5 18.5Z" />
              </svg>
            </span>
          </button>
          <div class="floating-support__hint">{floatingSupport.prompt}</div>
          <div class="floating-support__panel" id="floating-support-panel" hidden>
            <div class="floating-support__panel-inner">
              <div class="floating-support__panel-copy">
                <strong>{floatingSupport.title}</strong>
                <p>{floatingSupport.detail}</p>
              </div>
              <img
                class="floating-support__qr"
                src={`${base}/wechat-qr.png`}
                alt="微信联系二维码"
                width="549"
                height="542"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      )}

      <button class="back-to-top" id="back-to-top" type="button" aria-label="回到顶部">
        <span class="back-to-top__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 19V5" />
            <path d="m6 11 6-6 6 6" />
          </svg>
        </span>
      </button>
    </div>

    <script is:inline>
      (() => {
        const button = document.getElementById('back-to-top');
        if (!button) return;

        const toggle = () => {
          button.classList.toggle('is-visible', window.scrollY > 320);
        };

        button.addEventListener('click', () => {
          const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          window.scrollTo({ top: 0, behavior: prefersReducedMotion ? 'auto' : 'smooth' });
        });

        toggle();
        window.addEventListener('scroll', toggle, { passive: true });
      })();
    </script>
    <script is:inline>
      (() => {
        const trigger = document.getElementById('floating-support-trigger');
        const panel = document.getElementById('floating-support-panel');
        const root = document.getElementById('floating-support');
        if (!(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLElement) || !(root instanceof HTMLElement)) return;

        const setOpen = (open) => {
          panel.hidden = !open;
          trigger.setAttribute('aria-expanded', String(open));
          root.dataset.open = String(open);
        };

        trigger.addEventListener('click', (event) => {
          event.stopPropagation();
          setOpen(panel.hidden);
        });

        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Node) || root.contains(target)) return;
          setOpen(false);
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setOpen(false);
        });
      })();
    </script>
  </body>
</html>
