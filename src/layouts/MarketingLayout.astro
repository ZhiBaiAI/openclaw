---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'OpenClaw 安装教程、案例演示与本地部署服务说明。' } =
  Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Noto+Serif+SC:wght@500;700;900&display=swap');

      :root {
        --bg: #111417;
        --panel: rgba(20, 26, 33, 0.72);
        --panel-solid: #18212a;
        --panel-line: rgba(172, 188, 204, 0.18);
        --text: #f2eee7;
        --muted: #a5afba;
        --accent: #f0b56c;
        --accent-strong: #5ea3ff;
        --accent-soft: rgba(94, 163, 255, 0.16);
        --success: #8fd5a6;
        --shadow: 0 28px 90px rgba(0, 0, 0, 0.24);
        --radius-xl: 32px;
        --radius-lg: 22px;
        --max-width: 1180px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family: 'Manrope', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        background:
          radial-gradient(circle at top right, rgba(94, 163, 255, 0.2), transparent 25%),
          radial-gradient(circle at bottom left, rgba(240, 181, 108, 0.18), transparent 30%),
          linear-gradient(180deg, #141a1f 0%, #0f1215 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .shell {
        min-height: 100vh;
      }

      .noise {
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.06;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.07) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.07) 1px, transparent 1px);
        background-size: 26px 26px;
        mask-image: radial-gradient(circle at center, black 35%, transparent 90%);
      }

      .container {
        width: min(calc(100% - 32px), var(--max-width));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(18px);
        background: rgba(11, 14, 18, 0.72);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 18px 0;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 800;
        letter-spacing: 0.04em;
      }

      .brand-mark {
        width: 14px;
        height: 14px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--accent), var(--accent-strong));
        box-shadow: 0 0 24px rgba(94, 163, 255, 0.35);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 18px;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 13px 18px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          background-color 180ms ease;
      }

      .cta:hover {
        transform: translateY(-1px);
        border-color: rgba(255, 255, 255, 0.22);
      }

      .cta-primary {
        color: #121212;
        background: linear-gradient(135deg, #f3d3a6, #f0b56c);
        border-color: transparent;
        font-weight: 800;
      }

      .cta-secondary {
        background: rgba(255, 255, 255, 0.03);
      }

      .hero {
        padding: 72px 0 48px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.9fr);
        gap: 28px;
        align-items: stretch;
      }

      .hero-copy,
      .panel,
      .section-card {
        border: 1px solid var(--panel-line);
        border-radius: var(--radius-xl);
        background: var(--panel);
        box-shadow: var(--shadow);
        backdrop-filter: blur(16px);
      }

      .hero-copy {
        padding: 34px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(94, 163, 255, 0.12);
        color: #cfe1ff;
        font-size: 0.86rem;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        font-family: 'Noto Serif SC', 'Songti SC', serif;
        font-weight: 900;
        line-height: 1.08;
      }

      h1 {
        margin-top: 18px;
        font-size: clamp(2.5rem, 6vw, 5.1rem);
      }

      .lead {
        margin-top: 18px;
        font-size: 1.06rem;
        line-height: 1.9;
        color: var(--muted);
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 28px;
      }

      .hero-list {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-top: 28px;
      }

      .hero-list div {
        padding: 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .hero-list strong {
        display: block;
        margin-bottom: 6px;
        color: var(--accent);
      }

      .panel {
        padding: 28px;
      }

      .panel h2 {
        font-size: 1.8rem;
      }

      .panel p {
        color: var(--muted);
        line-height: 1.8;
      }

      .bullet-list {
        display: grid;
        gap: 12px;
        margin: 24px 0 0;
        padding: 0;
        list-style: none;
      }

      .bullet-list li {
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .section {
        padding: 24px 0 62px;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: end;
        margin-bottom: 18px;
      }

      .section-head p {
        max-width: 52ch;
        margin: 0;
        color: var(--muted);
        line-height: 1.8;
      }

      .card-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .section-card {
        padding: 24px;
      }

      .section-card p,
      .section-card li {
        color: var(--muted);
        line-height: 1.75;
      }

      .section-card ul {
        margin: 14px 0 0;
        padding-left: 18px;
      }

      .spotlight {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 18px;
      }

      .footer {
        padding: 18px 0 46px;
        color: var(--muted);
      }

      @media (max-width: 960px) {
        .hero-grid,
        .spotlight,
        .card-grid,
        .hero-list {
          grid-template-columns: 1fr;
        }

        .nav-inner,
        .section-head {
          align-items: start;
          flex-direction: column;
        }

        .nav-links {
          flex-wrap: wrap;
        }
      }

      @media (max-width: 640px) {
        .hero-copy,
        .panel,
        .section-card {
          padding: 22px;
          border-radius: 24px;
        }

        .hero {
          padding-top: 42px;
        }

        .container {
          width: min(calc(100% - 20px), var(--max-width));
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <div class="noise"></div>
      <header class="nav">
        <div class="container nav-inner">
          <a class="brand" href="/">
            <span class="brand-mark"></span>
            <span>OpenClaw 教程站</span>
          </a>
          <nav class="nav-links">
            <a href="/docs/">安装教程</a>
            <a href="/features/">功能页面</a>
            <a href="/cases/">案例演示</a>
            <a href="/service/">上门服务</a>
            <a class="cta cta-secondary" href="/contact/">联系与更新</a>
          </nav>
        </div>
      </header>
      <slot />
    </div>
  </body>
</html>
