---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'OpenClaw 交付、使用文档、案例与客户支持中心。' } =
  Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Noto+Serif+SC:wght@500;700;900&display=swap');

      :root {
        --bg: #f8f1e8;
        --bg-soft: #fff8f1;
        --panel: rgba(255, 250, 244, 0.84);
        --panel-solid: #fffaf4;
        --panel-line: rgba(126, 72, 42, 0.14);
        --text: #39241a;
        --muted: #756053;
        --accent: #d95e39;
        --accent-strong: #ef8f47;
        --accent-deep: #8d3424;
        --accent-soft: rgba(217, 94, 57, 0.12);
        --accent-soft-strong: rgba(239, 143, 71, 0.18);
        --success: #5f8967;
        --shadow: 0 22px 70px rgba(127, 79, 47, 0.14);
        --radius-xl: 32px;
        --radius-lg: 22px;
        --max-width: 1180px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family: 'Manrope', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        background:
          radial-gradient(circle at top left, rgba(255, 210, 170, 0.62), transparent 28%),
          radial-gradient(circle at top right, rgba(215, 93, 61, 0.18), transparent 24%),
          radial-gradient(circle at 20% 85%, rgba(239, 143, 71, 0.18), transparent 22%),
          linear-gradient(180deg, #fffaf4 0%, #f7efe5 45%, #f3e5d7 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .shell {
        min-height: 100vh;
      }

      .noise {
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.05;
        background-image:
          linear-gradient(rgba(121, 79, 51, 0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(121, 79, 51, 0.06) 1px, transparent 1px);
        background-size: 30px 30px;
        mask-image: radial-gradient(circle at center, black 30%, transparent 88%);
      }

      .container {
        width: min(calc(100% - 32px), var(--max-width));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(18px);
        background: rgba(255, 248, 240, 0.78);
        border-bottom: 1px solid rgba(126, 72, 42, 0.1);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 18px 0;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 800;
        letter-spacing: 0.04em;
        color: var(--accent-deep);
      }

      .brand-mark {
        width: 16px;
        height: 16px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--accent), var(--accent-strong));
        box-shadow: 0 10px 22px rgba(217, 94, 57, 0.34);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 18px;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .nav-links a:not(.cta) {
        position: relative;
        padding: 4px 0;
        transition: color 180ms ease;
      }

      .nav-links a:not(.cta)::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: -2px;
        height: 2px;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--accent), var(--accent-strong));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 180ms ease;
      }

      .nav-links a:not(.cta):hover {
        color: var(--accent-deep);
      }

      .nav-links a:not(.cta):hover::after {
        transform: scaleX(1);
      }

      .cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 13px 18px;
        border-radius: 999px;
        border: 1px solid rgba(126, 72, 42, 0.14);
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          background-color 180ms ease,
          box-shadow 180ms ease;
      }

      .cta:hover {
        transform: translateY(-1px);
        border-color: rgba(126, 72, 42, 0.24);
        box-shadow: 0 14px 26px rgba(181, 102, 58, 0.12);
      }

      .cta-primary {
        color: #fff8f4;
        background: linear-gradient(135deg, var(--accent), var(--accent-strong));
        border-color: transparent;
        font-weight: 800;
      }

      .cta-secondary {
        background: rgba(255, 250, 244, 0.72);
      }

      .hero {
        padding: 72px 0 48px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.9fr);
        gap: 28px;
        align-items: stretch;
      }

      .hero-copy,
      .panel,
      .section-card {
        border: 1px solid var(--panel-line);
        border-radius: var(--radius-xl);
        background: var(--panel);
        box-shadow: var(--shadow);
        backdrop-filter: blur(16px);
      }

      .hero-copy {
        padding: 34px;
        position: relative;
        overflow: hidden;
        background:
          radial-gradient(circle at top right, rgba(239, 143, 71, 0.16), transparent 30%),
          linear-gradient(180deg, rgba(255, 252, 247, 0.96), rgba(255, 247, 238, 0.88));
      }

      .hero-copy::before {
        content: '';
        position: absolute;
        inset: 0 auto auto 0;
        width: 180px;
        height: 180px;
        background: radial-gradient(circle, rgba(217, 94, 57, 0.16), transparent 70%);
        transform: translate(-24%, -26%);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent-deep);
        font-size: 0.86rem;
        font-weight: 700;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        font-family: 'Noto Serif SC', 'Songti SC', serif;
        font-weight: 900;
        line-height: 1.08;
      }

      h1 {
        margin-top: 18px;
        font-size: clamp(2.5rem, 6vw, 5.1rem);
      }

      .lead {
        margin-top: 18px;
        font-size: 1.06rem;
        line-height: 1.9;
        color: var(--muted);
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 28px;
      }

      .hero-list {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-top: 28px;
      }

      .hero-list div {
        padding: 16px;
        border-radius: 18px;
        background: rgba(255, 248, 241, 0.86);
        border: 1px solid rgba(217, 94, 57, 0.12);
      }

      .hero-list strong {
        display: block;
        margin-bottom: 6px;
        color: var(--accent);
      }

      .panel {
        padding: 28px;
        background:
          radial-gradient(circle at top right, rgba(217, 94, 57, 0.1), transparent 28%),
          rgba(255, 250, 245, 0.84);
      }

      .panel h2 {
        font-size: 1.8rem;
      }

      .panel p {
        color: var(--muted);
        line-height: 1.8;
      }

      .bullet-list {
        display: grid;
        gap: 12px;
        margin: 24px 0 0;
        padding: 0;
        list-style: none;
      }

      .bullet-list li {
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255, 247, 240, 0.88);
        border: 1px solid rgba(217, 94, 57, 0.12);
      }

      .section {
        padding: 24px 0 62px;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: end;
        margin-bottom: 18px;
      }

      .section-head p {
        max-width: 52ch;
        margin: 0;
        color: var(--muted);
        line-height: 1.8;
      }

      .card-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .section-card {
        padding: 24px;
        background:
          linear-gradient(180deg, rgba(255, 252, 247, 0.96), rgba(255, 248, 241, 0.86));
        transition:
          transform 180ms ease,
          box-shadow 180ms ease,
          border-color 180ms ease;
      }

      .section-card:hover {
        transform: translateY(-3px);
        border-color: rgba(217, 94, 57, 0.18);
        box-shadow: 0 22px 42px rgba(161, 88, 48, 0.14);
      }

      .section-card p,
      .section-card li {
        color: var(--muted);
        line-height: 1.75;
      }

      .section-card ul {
        margin: 14px 0 0;
        padding-left: 18px;
      }

      .spotlight {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 18px;
      }

      .footer {
        padding: 18px 0 46px;
        color: var(--muted);
      }

      code {
        padding: 0.18rem 0.45rem;
        border-radius: 999px;
        background: rgba(217, 94, 57, 0.08);
        color: var(--accent-deep);
        font-size: 0.92em;
      }

      ::selection {
        background: rgba(239, 143, 71, 0.24);
      }

      @media (max-width: 960px) {
        .hero-grid,
        .spotlight,
        .card-grid,
        .hero-list {
          grid-template-columns: 1fr;
        }

        .nav-inner,
        .section-head {
          align-items: start;
          flex-direction: column;
        }

        .nav-links {
          flex-wrap: wrap;
        }
      }

      @media (max-width: 640px) {
        .hero-copy,
        .panel,
        .section-card {
          padding: 22px;
          border-radius: 24px;
        }

        .hero {
          padding-top: 42px;
        }

        .container {
          width: min(calc(100% - 20px), var(--max-width));
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <div class="noise"></div>
      <header class="nav">
        <div class="container nav-inner">
          <a class="brand" href={withBase('/')}>
            <span class="brand-mark"></span>
            <span>OpenClaw 交付中心</span>
          </a>
          <nav class="nav-links">
            <a href={withBase('/')}>首页</a>
            <a href={withBase('/features/')}>方案能力</a>
            <a href={withBase('/cases/')}>真实案例</a>
            <a href={withBase('/docs/')}>使用文档</a>
            <a href="https://skillhub.tencent.com/" target="_blank" rel="noreferrer">腾讯 SkillHub</a>
            <a href={withBase('/links/')}>资源导航</a>
            <a href={withBase('/service/')}>交付服务</a>
            <a class="cta cta-secondary" href={withBase('/contact/')}>交付支持</a>
          </nav>
        </div>
      </header>
      <slot />
    </div>
  </body>
</html>
